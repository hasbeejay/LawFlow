@inherits LayoutComponentBase
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@inject NotificationService NotificationService
@inject CustomAuthenticationStateProvider CustomAuth
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@inject ProtectedLocalStorage LocalStorage

<MudThemeProvider @bind-IsDarkMode="_isDarkMode" Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider FullWidth="true" MaxWidth="MaxWidth.ExtraSmall" />
<MudSnackbarProvider />

<AuthorizeView Context="authContext">
    <Authorized>
        @if (IsLoginPage())
        {
            @Body
        }
        else
        {
            <MudLayout Class="lf-app-layout">
                <MudAppBar Elevation="0" Color="Color.Surface" Dense="false" Fixed="false" Class="lf-appbar lf-topbar">
                    <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@ToggleDrawer" Class="lf-toolbar-icon" />
                    <MudText Typo="Typo.h5" Class="ml-3 font-weight-bold lf-brand">
                        <MudIcon Icon="@Icons.Material.Filled.Gavel" Color="Color.Primary" />
                        <span class="lf-brand-wordmark">Law<span class="lf-brand-accent">Flow</span></span>
                    </MudText>
                    
                    <MudSpacer />
                    
                    <!-- Notification Bell -->
                    <MudMenu Icon="@Icons.Material.Filled.Notifications" Color="Color.Default" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight" MaxHeight="300">
                        <ActivatorContent>
                            <MudBadge Content="@_unreadNotificationCount" Color="Color.Error" Overlap="true" Visible="@(_unreadNotificationCount > 0)">
                                <MudIcon Icon="@Icons.Material.Filled.Notifications" Color="Color.Default" Class="lf-toolbar-icon" />
                            </MudBadge>
                        </ActivatorContent>
                        <ChildContent>
                            <div style="width: 280px; padding: 12px;">
                                <div class="d-flex justify-space-between align-center mb-2">
                                    <MudText Typo="Typo.subtitle2" Style="font-weight: 600;">Notifications</MudText>
                                    @if (_unreadNotificationCount > 0)
                                    {
                                        <MudButton Size="Size.Small" Color="Color.Primary" OnClick="MarkAllNotificationsAsRead">Mark all read</MudButton>
                                    }
                                </div>
                                <MudDivider Class="mb-2" />
                                @if (_notifications.Count == 0)
                                {
                                    <MudText Typo="Typo.body2" Align="Align.Center" Class="py-4 text-muted">No new alerts</MudText>
                                }
                                else
                                {
                                    @foreach (var n in _notifications)
                                    {
                                        <div class="py-2" style="border-bottom: 1px solid var(--lf-border); cursor: pointer;" @onclick="() => MarkRead(n.Id)">
                                            <MudText Typo="Typo.caption" Color="Color.Primary" Class="d-block">@n.Title</MudText>
                                            <MudText Typo="Typo.body2" Class="d-block" Style="font-size: 12px; line-height: 1.2;">@n.Message</MudText>
                                            <MudText Typo="Typo.caption" Class="text-muted" Style="font-size: 10px;">@n.CreatedAt.ToLocalTime().ToString("t")</MudText>
                                        </div>
                                    }
                                }
                            </div>
                        </ChildContent>
                    </MudMenu>

                    <!-- Theme Toggle -->
                    <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)" 
                                   Color="Color.Inherit" 
                                   OnClick="ToggleTheme" 
                                   Class="mx-2 lf-toolbar-icon" />

                    <!-- User Profile Menu -->
                    <MudMenu AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                        <ActivatorContent>
                            <MudChip T="string" Color="Color.Primary" Variant="Variant.Filled" Label="true" Class="lf-user-chip" Style="cursor: pointer;">
                                @authContext.User.Identity?.Name
                            </MudChip>
                        </ActivatorContent>
                        <ChildContent>
                            <div class="px-4 py-2" style="min-width: 150px;">
                                <MudText Typo="Typo.subtitle2" Style="font-weight:600;">@authContext.User.Identity?.Name</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Primary">Role: @GetUserRole(authContext.User)</MudText>
                            </div>
                            <MudDivider />
                            <MudMenuItem Icon="@Icons.Material.Filled.Dashboard" OnClick="NavigateToDashboard">My Dashboard</MudMenuItem>
                            <MudMenuItem Icon="@Icons.Material.Filled.Logout" OnClick="Logout">Sign Out</MudMenuItem>
                        </ChildContent>
                    </MudMenu>

                    <!-- Dedicated Logout Button -->
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Inherit"
                               StartIcon="@Icons.Material.Filled.Logout"
                               OnClick="Logout"
                               Class="ml-2 lf-signout-btn">
                        Sign out
                    </MudButton>
                </MudAppBar>

                <!-- Sidebar Drawer -->
                <MudDrawer @bind-Open="_drawerOpen" Elevation="0" Color="Color.Surface" ClipMode="DrawerClipMode.Always" Class="lf-drawer">
                    <div class="pa-4 d-flex flex-column align-center lf-drawer-profile">
                        <MudAvatar Color="Color.Primary" Style="height:60px; width:60px; font-size: 24px; font-weight:600; border-radius: 12px;">
                            @(authContext.User.Identity?.Name?[..1].ToUpper() ?? "U")
                        </MudAvatar>
                        <MudText Typo="Typo.subtitle1" Class="mt-2 font-weight-bold">@authContext.User.FindFirst(System.Security.Claims.ClaimTypes.GivenName)?.Value</MudText>
                        <MudChip T="string" Size="Size.Small" Color="Color.Primary" Style="border-radius: 6px; font-size: 11px;">@GetUserRole(authContext.User)</MudChip>
                    </div>
                    
                    <MudNavMenu Class="pa-2">
                        @if (_currentUser != null && _currentUser.Identity?.IsAuthenticated == true)
                        {
                            var roleLower = GetUserRole(_currentUser).ToLower();
                            <MudNavLink Href="@($"/{roleLower}/dashboard")" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">Dashboard</MudNavLink>
                            <MudNavLink Href="@($"/{roleLower}/cases")" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.FolderOpen">All Case Files</MudNavLink>
                        }
                        else
                        {
                            <MudNavLink Href="/dashboard" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">Dashboard</MudNavLink>
                            <MudNavLink Href="/cases" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.FolderOpen">All Case Files</MudNavLink>
                        }
                        
                        <AuthorizeView Roles="Judge">
                            <MudNavLink Href="/judge/cases" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Gavel">Presiding Caseload</MudNavLink>
                        </AuthorizeView>

                        <AuthorizeView Roles="Lawyer">
                            <MudNavLink Href="/lawyer/cases" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.AccountBalance">Attorney Cabinet</MudNavLink>
                        </AuthorizeView>

                        <AuthorizeView Roles="Client">
                            <MudNavLink Href="/client/submit" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.PostAdd">Lodge Incident (FIR)</MudNavLink>
                        </AuthorizeView>

                        <AuthorizeView Roles="Police">
                            <MudNavLink Href="/police/cases" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.LocalPolice">Investigation Queue</MudNavLink>
                            <MudNavLink Href="/police/registry" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.ReceiptLong">Criminal Registry</MudNavLink>
                        </AuthorizeView>

                        <AuthorizeView Roles="Clerk,Admin">
                            <MudNavLink Href="/hearings" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.CalendarMonth">Schedule Hearings</MudNavLink>
                        </AuthorizeView>

                        <AuthorizeView Roles="Clerk">
                            <MudNavLink Href="/clerk/verdicts" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.AppRegistration">Verdict Registry</MudNavLink>
                        </AuthorizeView>
                        
                        <AuthorizeView Roles="Admin">
                            <MudNavLink Href="/admin/users" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.People">User Management</MudNavLink>
                            <MudNavLink Href="/admin/logs" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.History">Audit Logs</MudNavLink>
                        </AuthorizeView>
                    </MudNavMenu>
                </MudDrawer>

                <MudMainContent Class="pa-6 lf-main-content lf-page-transition">
                    @Body
                </MudMainContent>
            </MudLayout>
        }
    </Authorized>
    <NotAuthorized>
        <!-- Custom styled wrapper for Login page if not authorized -->
        @Body
    </NotAuthorized>
</AuthorizeView>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>

@code {
    private bool _drawerOpen = true;
    private bool _isDarkMode = false;
    private int _unreadNotificationCount = 0;
    private List<Notification> _notifications = new();
    private ClaimsPrincipal? _currentUser;

    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight()
        {
            Primary = "#1F3F65",
            Secondary = "#2F8F83",
            Tertiary = "#BF8B30",
            Background = "#F3F6FB",
            Surface = "#FFFFFF",
            AppbarBackground = "#FFFFFF",
            AppbarText = "#1A2738",
            DrawerBackground = "#F7F9FD",
            DrawerText = "#2B3D55",
            Success = "#1F9D67",
            Warning = "#CB8B2A",
            Error = "#C84F4F",
            Info = "#3B67D6",
            TableHover = "rgba(31, 63, 101, 0.04)"
        },
        PaletteDark = new PaletteDark()
        {
            Primary = "#8FB7FF",
            Secondary = "#59C1B2",
            Tertiary = "#E0B66D",
            Background = "#0A121D",
            Surface = "#131F31",
            AppbarBackground = "#111A2A",
            AppbarText = "#E5ECF7",
            DrawerBackground = "#0F1A2A",
            DrawerText = "#C4D4EB",
            Success = "#54C783",
            Warning = "#D6A34A",
            Error = "#F38B8B",
            Info = "#83A9FF",
            TableHover = "rgba(143, 183, 255, 0.10)"
        },
        Typography = new Typography()
        {
            Default = new DefaultTypography()
            {
                FontFamily = new[] { "Plus Jakarta Sans", "Outfit", "Segoe UI", "sans-serif" }
            },
            H1 = new H1Typography() { FontFamily = new[] { "Sora", "Plus Jakarta Sans", "Segoe UI", "sans-serif" } },
            H2 = new H2Typography() { FontFamily = new[] { "Sora", "Plus Jakarta Sans", "Segoe UI", "sans-serif" } },
            H3 = new H3Typography() { FontFamily = new[] { "Sora", "Plus Jakarta Sans", "Segoe UI", "sans-serif" } },
            H4 = new H4Typography() { FontFamily = new[] { "Sora", "Plus Jakarta Sans", "Segoe UI", "sans-serif" } },
            H5 = new H5Typography() { FontFamily = new[] { "Sora", "Plus Jakarta Sans", "Segoe UI", "sans-serif" } },
            H6 = new H6Typography() { FontFamily = new[] { "Sora", "Plus Jakarta Sans", "Segoe UI", "sans-serif" } },
            Button = new ButtonTypography()
            {
                FontFamily = new[] { "Plus Jakarta Sans", "Outfit", "Segoe UI", "sans-serif" },
                FontWeight = "700"
            }
        },
        LayoutProperties = new LayoutProperties()
        {
            DefaultBorderRadius = "12px",
            DrawerWidthLeft = "272px"
        }
    };

    protected override async Task OnInitializedAsync()
    {
        NotificationService.OnNotificationChanged += HandleNotificationChange;
        await LoadThemeSetting();
    }

    protected override async Task OnParametersSetAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _currentUser = authState.User;

        if (!_currentUser.Identity?.IsAuthenticated ?? true)
        {
            var uri = Navigation.ToBaseRelativePath(Navigation.Uri);
            if (!uri.StartsWith("login", StringComparison.OrdinalIgnoreCase) && !uri.StartsWith("register", StringComparison.OrdinalIgnoreCase))
            {
                Navigation.NavigateTo("/login");
            }
        }
        else
        {
            await LoadNotifications();
            var uri = Navigation.ToBaseRelativePath(Navigation.Uri);
            if (uri.StartsWith("login", StringComparison.OrdinalIgnoreCase) || uri.StartsWith("register", StringComparison.OrdinalIgnoreCase))
            {
                Navigation.NavigateTo("/dashboard");
            }
        }
    }

    private async Task LoadThemeSetting()
    {
        try
        {
            var res = await LocalStorage.GetAsync<bool>("DarkMode");
            if (res.Success)
            {
                _isDarkMode = res.Value;
            }
        }
        catch
        {
            // Ignore during pre-rendering
        }
    }

    private async Task ToggleTheme()
    {
        _isDarkMode = !_isDarkMode;
        try
        {
            await LocalStorage.SetAsync("DarkMode", _isDarkMode);
        }
        catch {}
    }

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    private string GetUserRole(ClaimsPrincipal user)
    {
        return user.FindFirst(ClaimTypes.Role)?.Value ?? "Guest";
    }

    private async Task LoadNotifications()
    {
        if (_currentUser?.Identity?.IsAuthenticated ?? false)
        {
            var userId = _currentUser.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            if (!string.IsNullOrEmpty(userId))
            {
                _notifications = await NotificationService.GetNotificationsForUserAsync(userId);
                _unreadNotificationCount = await NotificationService.GetUnreadCountAsync(userId);
                StateHasChanged();
            }
        }
    }

    private async void HandleNotificationChange()
    {
        await InvokeAsync(async () =>
        {
            await LoadNotifications();
        });
    }

    private async Task MarkRead(int notificationId)
    {
        await NotificationService.MarkAsReadAsync(notificationId);
    }

    private async Task MarkAllNotificationsAsRead()
    {
        if (_currentUser != null)
        {
            var userId = _currentUser.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            if (!string.IsNullOrEmpty(userId))
            {
                await NotificationService.MarkAllAsReadAsync(userId);
            }
        }
    }

    private void NavigateToDashboard()
    {
        if (_currentUser != null && _currentUser.Identity?.IsAuthenticated == true)
        {
            var roleLower = GetUserRole(_currentUser).ToLower();
            Navigation.NavigateTo($"/{roleLower}/dashboard");
        }
        else
        {
            Navigation.NavigateTo("/dashboard");
        }
    }

    private bool IsLoginPage()
    {
        var relative = Navigation.ToBaseRelativePath(Navigation.Uri);
        return relative.StartsWith("login", StringComparison.OrdinalIgnoreCase) || relative.StartsWith("register", StringComparison.OrdinalIgnoreCase);
    }

    private async Task Logout()
    {
        await CustomAuth.UpdateAuthenticationState(null);
        Navigation.NavigateTo("/login", forceLoad: true);
    }

    public void Dispose()
    {
        NotificationService.OnNotificationChanged -= HandleNotificationChange;
    }
}
