@inherits LayoutComponentBase
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@inject NotificationService NotificationService
@inject CustomAuthenticationStateProvider CustomAuth
@implements IDisposable

@* Legacy MudBlazor providers kept mounted so un-migrated pages keep working through the transition. *@
<MudThemeProvider Theme="_legacyTheme" IsDarkMode="false" />
<MudPopoverProvider />
<MudDialogProvider FullWidth="true" MaxWidth="MaxWidth.ExtraSmall" />
<MudSnackbarProvider />

<LfToastHost />

<AuthorizeView Context="authContext">
    <Authorized>
        @if (IsLoginPage())
        {
            <main class="min-h-dvh bg-canvas">@Body</main>
        }
        else
        {
            <div class="min-h-dvh bg-canvas text-ink flex flex-col">
                <!-- Top bar — liquid-glass chrome -->
                <header class="sticky top-0 z-30 h-14 lf-glass-bar">
                    <div class="h-full px-4 lg:px-6 flex items-center gap-3">
                        <button type="button" @onclick="ToggleDrawer"
                                class="lg:hidden lf-btn-ghost p-2 -ml-1 rounded-card border border-hairline"
                                aria-label="Toggle navigation">
                            <LfIcon Name="menu" Size="16" />
                        </button>

                        <LfBrand Href="@DashboardHref(_currentUser)" />

                        <!-- Global search -->
                        <div class="hidden md:flex flex-1 max-w-md mx-3">
                            <form @onsubmit="HandleTopSearch" @onsubmit:preventDefault="true"
                                  class="w-full flex items-center gap-2 px-3 py-1.5 rounded-card border border-hairline bg-surface text-sm focus-within:border-primary/40 transition-colors">
                                <LfIcon Name="search" Size="14" />
                                <input id="lf-top-search"
                                       @bind="_topSearchQuery"
                                       @bind:event="oninput"
                                       type="text"
                                       placeholder="Search cases, people, hearings..."
                                       class="flex-1 bg-transparent text-ink placeholder:text-muted outline-none min-w-0" />
                            </form>
                        </div>

                        <div class="ml-auto flex items-center gap-1.5">
                            <!-- Notifications -->
                            <LfMenu>
                                <Trigger>
                                    <button type="button"
                                            class="lf-btn-ghost p-2 rounded-card border border-hairline hover:border-primary/40 relative"
                                            aria-label="Notifications">
                                        <LfIcon Name="bell" Size="16" />
                                        @if (_unreadNotificationCount > 0)
                                        {
                                            <span class="absolute -top-0.5 -right-0.5 min-w-[16px] h-4 px-1 rounded-full bg-danger text-white font-mono text-2xs inline-flex items-center justify-center">
                                                @(_unreadNotificationCount > 9 ? "9+" : _unreadNotificationCount.ToString())
                                            </span>
                                        }
                                    </button>
                                </Trigger>
                                <ChildContent>
                                    <div class="px-3 py-2 flex items-center justify-between">
                                        <div class="text-xs uppercase tracking-wider text-muted font-medium">Notifications</div>
                                        @if (_unreadNotificationCount > 0)
                                        {
                                            <button @onclick="MarkAllNotificationsAsRead" class="text-xs text-primary hover:underline">Mark all read</button>
                                        }
                                    </div>
                                    <div class="lf-rule"></div>
                                    <div class="max-h-80 overflow-y-auto py-1 min-w-[300px]">
                                        @if (_notifications.Count == 0)
                                        {
                                            <div class="px-3 py-6 text-center text-sm text-muted">No new alerts</div>
                                        }
                                        else
                                        {
                                            @foreach (var n in _notifications)
                                            {
                                                <button @onclick="() => MarkRead(n.Id)"
                                                        class="w-full text-left px-3 py-2 rounded-xs hover:bg-ink/5 transition-colors flex items-start gap-2.5">
                                                    <span class="w-1.5 h-1.5 rounded-full @(n.IsRead ? "bg-hairline" : "bg-primary") mt-1.5 shrink-0"></span>
                                                    <span class="flex-1 min-w-0">
                                                        <span class="block text-xs font-medium text-primary truncate">@n.Title</span>
                                                        <span class="block text-sm text-ink mt-0.5 line-clamp-2">@n.Message</span>
                                                        <span class="block font-mono text-2xs text-muted mt-1">@n.CreatedAt.ToLocalTime().ToString("HH:mm · MMM d")</span>
                                                    </span>
                                                </button>
                                            }
                                        }
                                    </div>
                                </ChildContent>
                            </LfMenu>

                            <LfThemeToggle />

                            <!-- User menu -->
                            <LfMenu>
                                <Trigger>
                                    <button type="button" class="lf-btn-ghost flex items-center gap-2 pl-1 pr-2 py-1 rounded-card border border-hairline hover:border-primary/40">
                                        <LfAvatar Name="@(authContext.User.FindFirst(ClaimTypes.GivenName)?.Value ?? authContext.User.Identity?.Name)" Size="sm" />
                                        <span class="hidden sm:flex flex-col text-left leading-tight">
                                            <span class="text-xs font-medium truncate max-w-[120px]">@(authContext.User.FindFirst(ClaimTypes.GivenName)?.Value ?? authContext.User.Identity?.Name)</span>
                                            <span class="font-mono text-2xs text-muted uppercase">@GetUserRole(authContext.User)</span>
                                        </span>
                                        <LfIcon Name="chevron-down" Size="13" Class="text-muted" />
                                    </button>
                                </Trigger>
                                <ChildContent>
                                    <div class="px-3 py-2">
                                        <div class="text-sm font-medium">@authContext.User.Identity?.Name</div>
                                        <div class="font-mono text-2xs text-muted uppercase mt-0.5">role · @GetUserRole(authContext.User)</div>
                                    </div>
                                    <div class="lf-rule"></div>
                                    <LfMenuItem Icon="layout-dashboard" OnClick="NavigateToDashboard">My Dashboard</LfMenuItem>
                                    <LfMenuItem Icon="log-out" OnClick="Logout">Sign Out</LfMenuItem>
                                </ChildContent>
                            </LfMenu>
                        </div>
                    </div>
                </header>

                <div class="flex-1 relative">
                    <!-- DESKTOP SIDEBAR — fixed overlay, liquid glass.
                         Content scrolls UNDER the right edge so the blur picks up depth. -->
                    <aside class="hidden lg:flex flex-col fixed top-14 left-0 bottom-0 w-64 z-20 lf-glass lf-glass-shine border-r border-hairline overflow-y-auto">
                        <SidebarNav User="_currentUser" />
                    </aside>

                    <!-- MOBILE DRAWER — same glass, overlay only when open -->
                    @if (_drawerOpen)
                    {
                        <div @onclick="ToggleDrawer" class="lg:hidden fixed inset-0 z-30 bg-black/40 backdrop-blur-sm"></div>
                        <aside class="lg:hidden fixed top-14 bottom-0 left-0 w-64 z-40 lf-glass border-r border-hairline overflow-y-auto animate-fade-in-up">
                            <SidebarNav User="_currentUser" />
                        </aside>
                    }

                    <!-- Main content — ml-64 on lg+ to clear the fixed sidebar -->
                    <main class="relative lg:ml-64 min-w-0">
                        <div class="px-4 sm:px-6 lg:px-8 py-6 animate-fade-in-up">
                            @Body
                        </div>
                    </main>
                </div>
            </div>
        }
    </Authorized>
    <NotAuthorized>
        <main class="min-h-dvh bg-canvas">@Body</main>
    </NotAuthorized>
</AuthorizeView>

<div id="blazor-error-ui" class="fixed bottom-4 left-4 z-[200] px-4 py-3 lf-elevated text-sm hidden">
    An unhandled error has occurred.
    <a href="" class="reload text-primary underline ml-1">Reload</a>
    <a class="dismiss ml-2 text-muted">✕</a>
</div>

@code {
    private bool _drawerOpen = false;
    private int _unreadNotificationCount = 0;
    private List<Notification> _notifications = new();
    private ClaimsPrincipal? _currentUser;
    private string _topSearchQuery = string.Empty;

    // Kept minimal — just enough so legacy MudBlazor pages don't blow up while we migrate them.
    private readonly MudTheme _legacyTheme = new()
    {
        PaletteLight = new PaletteLight() { Primary = "#6D4FE8", Secondary = "#B5862A" },
        LayoutProperties = new LayoutProperties() { DefaultBorderRadius = "10px" }
    };

    protected override void OnInitialized()
    {
        NotificationService.OnNotificationChanged += HandleNotificationChange;
    }

    protected override async Task OnParametersSetAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _currentUser = authState.User;

        if (!_currentUser.Identity?.IsAuthenticated ?? true)
        {
            var uri = Navigation.ToBaseRelativePath(Navigation.Uri);
            if (!uri.StartsWith("login", StringComparison.OrdinalIgnoreCase))
            {
                Navigation.NavigateTo("/login");
            }
        }
        else
        {
            await LoadNotifications();
            var uri = Navigation.ToBaseRelativePath(Navigation.Uri);
            if (uri.StartsWith("login", StringComparison.OrdinalIgnoreCase))
            {
                Navigation.NavigateTo("/dashboard");
            }
        }
    }

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    private string GetUserRole(ClaimsPrincipal user) =>
        user.FindFirst(ClaimTypes.Role)?.Value ?? "Guest";

    private string DashboardHref(ClaimsPrincipal? user)
    {
        if (user?.Identity?.IsAuthenticated == true)
            return $"/{GetUserRole(user).ToLowerInvariant()}/dashboard";
        return "/dashboard";
    }

    private async Task LoadNotifications()
    {
        if (_currentUser?.Identity?.IsAuthenticated ?? false)
        {
            var userId = _currentUser.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            if (!string.IsNullOrEmpty(userId))
            {
                _notifications = await NotificationService.GetNotificationsForUserAsync(userId);
                _unreadNotificationCount = await NotificationService.GetUnreadCountAsync(userId);
                StateHasChanged();
            }
        }
    }

    private async void HandleNotificationChange() =>
        await InvokeAsync(async () => await LoadNotifications());

    private async Task MarkRead(int notificationId) =>
        await NotificationService.MarkAsReadAsync(notificationId);

    private async Task MarkAllNotificationsAsRead()
    {
        var userId = _currentUser?.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        if (!string.IsNullOrEmpty(userId))
            await NotificationService.MarkAllAsReadAsync(userId);
    }

    private void NavigateToDashboard() =>
        Navigation.NavigateTo(DashboardHref(_currentUser));

    private Task HandleTopSearch()
    {
        var basePath = _currentUser?.Identity?.IsAuthenticated == true
            ? $"/{GetUserRole(_currentUser).ToLowerInvariant()}/cases"
            : "/cases";

        var term = _topSearchQuery?.Trim();
        var target = string.IsNullOrEmpty(term)
            ? basePath
            : $"{basePath}?q={Uri.EscapeDataString(term)}";

        Navigation.NavigateTo(target);
        return Task.CompletedTask;
    }

    private bool IsLoginPage()
    {
        var relative = Navigation.ToBaseRelativePath(Navigation.Uri);
        return relative.StartsWith("login", StringComparison.OrdinalIgnoreCase);
    }

    private async Task Logout()
    {
        await CustomAuth.UpdateAuthenticationState(null);
        Navigation.NavigateTo("/login", forceLoad: true);
    }

    public void Dispose()
    {
        NotificationService.OnNotificationChanged -= HandleNotificationChange;
    }
}
