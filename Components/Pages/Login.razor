@page "/login"
@layout Layout.MainLayout
@inject AuthService AuthService
@inject CustomAuthenticationStateProvider CustomAuth
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>Sign In - LawFlow</PageTitle>

<div class="lf-auth-shell lf-page-transition">
    <div class="lf-auth-grid">
        <section class="lf-auth-brand lf-glass-panel">
            <div class="d-flex align-center">
                <MudIcon Icon="@Icons.Material.Filled.Gavel" Color="Color.Primary" Size="Size.Large" Style="font-size: 36px;" />
                <MudText Typo="Typo.h4" Class="ml-2 font-weight-bold lf-brand">
                    <span class="lf-brand-wordmark">Law<span class="lf-brand-accent">Flow</span></span>
                </MudText>
            </div>

            <div class="lf-auth-kicker mt-8">Judicial Operations Platform</div>
            <h1 class="lf-auth-title">Secure case intelligence for courts, counsel, and investigators.</h1>
            <p class="lf-auth-subtitle">
                Centralized filing, assignment, hearing schedules, and verdict workflows with role-aware controls and a complete audit trail.
            </p>

            <div class="lf-auth-meta">
                <div class="lf-auth-meta-card">
                    <div class="lf-auth-meta-label">Workflow</div>
                    <div class="lf-auth-meta-value">11-stage lifecycle</div>
                </div>
                <div class="lf-auth-meta-card">
                    <div class="lf-auth-meta-label">Roles</div>
                    <div class="lf-auth-meta-value">Admin to Clerk</div>
                </div>
                <div class="lf-auth-meta-card">
                    <div class="lf-auth-meta-label">Mode</div>
                    <div class="lf-auth-meta-value">Realtime + audited</div>
                </div>
            </div>
        </section>

        <section class="lf-auth-card lf-glass-panel">
            <MudText Typo="Typo.h5" Class="font-weight-bold mb-1">Welcome back</MudText>
            <MudText Typo="Typo.body2" Class="text-muted mb-5">Sign in to continue into your judicial workspace.</MudText>

            <EditForm Model="@_loginModel" OnValidSubmit="HandleLogin">
                <DataAnnotationsValidator />

                <MudTextField @bind-Value="_loginModel.Username"
                              Label="Username"
                              Variant="Variant.Outlined"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Person"
                              For="@(() => _loginModel.Username)"
                              Class="mb-4" />

                <MudTextField @bind-Value="_loginModel.Password"
                              Label="Password"
                              Variant="Variant.Outlined"
                              InputType="@_passwordInput"
                              Adornment="Adornment.End"
                              AdornmentIcon="@_passwordInputIcon"
                              OnAdornmentClick="TogglePasswordVisibility"
                              For="@(() => _loginModel.Password)"
                              Class="mb-5" />

                <MudButton ButtonType="ButtonType.Submit"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           Size="Size.Large"
                           Style="height: 50px;"
                           Disabled="@_loading">
                    @if (_loading)
                    {
                        <MudProgressCircular Color="Color.Secondary" Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        <span>Signing in...</span>
                    }
                    else
                    {
                        <span>Sign in to LawFlow</span>
                    }
                </MudButton>
            </EditForm>

            <div class="lf-auth-demo">
                <MudText Typo="Typo.subtitle2" Class="font-weight-bold mb-3">
                    <MudIcon Icon="@Icons.Material.Filled.Bolt" Color="Color.Warning" Size="Size.Small" Class="mr-1" />
                    Quick demo access (Password: Password123!)
                </MudText>
                <MudGrid Spacing="1">
                    <MudItem xs="6" sm="4">
                        <MudButton FullWidth="true" Variant="Variant.Outlined" Size="Size.Small" Color="Color.Primary" OnClick='() => AutoFill("admin")'>Admin</MudButton>
                    </MudItem>
                    <MudItem xs="6" sm="4">
                        <MudButton FullWidth="true" Variant="Variant.Outlined" Size="Size.Small" Color="Color.Primary" OnClick='() => AutoFill("judge_ali")'>Judge</MudButton>
                    </MudItem>
                    <MudItem xs="6" sm="4">
                        <MudButton FullWidth="true" Variant="Variant.Outlined" Size="Size.Small" Color="Color.Primary" OnClick='() => AutoFill("lawyer_faisal")'>Lawyer</MudButton>
                    </MudItem>
                    <MudItem xs="6" sm="4">
                        <MudButton FullWidth="true" Variant="Variant.Outlined" Size="Size.Small" Color="Color.Primary" OnClick='() => AutoFill("client_zaheer")'>Client</MudButton>
                    </MudItem>
                    <MudItem xs="6" sm="4">
                        <MudButton FullWidth="true" Variant="Variant.Outlined" Size="Size.Small" Color="Color.Primary" OnClick='() => AutoFill("police_rahim")'>Police</MudButton>
                    </MudItem>
                    <MudItem xs="6" sm="4">
                        <MudButton FullWidth="true" Variant="Variant.Outlined" Size="Size.Small" Color="Color.Primary" OnClick='() => AutoFill("clerk_ahmad")'>Clerk</MudButton>
                    </MudItem>
                </MudGrid>
            </div>
        </section>
    </div>
</div>

@code {
    private LoginViewModel _loginModel = new();
    private bool _loading = false;
    private bool _showPassword = false;
    private InputType _passwordInput = InputType.Password;
    private string _passwordInputIcon = Icons.Material.Filled.VisibilityOff;

    private void TogglePasswordVisibility()
    {
        _showPassword = !_showPassword;
        _passwordInput = _showPassword ? InputType.Text : InputType.Password;
        _passwordInputIcon = _showPassword ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff;
    }

    private void AutoFill(string username)
    {
        _loginModel.Username = username;
        _loginModel.Password = "Password123!";
    }

    private async Task HandleLogin()
    {
        _loading = true;
        try
        {
            var session = await AuthService.LoginAsync(_loginModel.Username, _loginModel.Password);
            if (session != null)
            {
                await CustomAuth.UpdateAuthenticationState(session);
                Snackbar.Add($"Logged in successfully as {session.FullName}", Severity.Success);
                var roleRoute = string.IsNullOrWhiteSpace(session.Role)
                    ? "client"
                    : session.Role.ToLowerInvariant();
                Navigation.NavigateTo($"/{roleRoute}/dashboard", replace: true);
            }
            else
            {
                Snackbar.Add("Invalid username or password.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Login failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    public class LoginViewModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Username is required")]
        public string Username { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Password is required")]
        public string Password { get; set; } = string.Empty;
    }
}
