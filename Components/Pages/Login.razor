@page "/login"
@layout Layout.MainLayout
@inject AuthService AuthService
@inject CustomAuthenticationStateProvider CustomAuth
@inject NavigationManager Navigation
@inject ToastService Toast

<PageTitle>Sign In — LawFlow</PageTitle>


<div class="min-h-dvh w-full bg-canvas relative overflow-hidden">
    <!-- Decorative grid backdrop (radial-masked, faint) -->
    <div class="absolute inset-0 grid-bg opacity-60 pointer-events-none"></div>

    <div class="relative min-h-dvh flex flex-col">
        <!-- Header strip -->
        <header class="h-14 px-6 lg:px-10 flex items-center justify-between border-b border-hairline bg-canvas/70 backdrop-blur">
            <LfBrand Href="/login" />
            <div class="flex items-center gap-3">
                <span class="hidden md:inline-flex items-center gap-1.5 font-mono text-2xs text-muted uppercase tracking-wider">
                    <span class="w-1.5 h-1.5 rounded-full bg-success animate-pulse-dot"></span>
                    session · gateway-01
                </span>
                <LfThemeToggle />
            </div>
        </header>

        <div class="flex-1 grid lg:grid-cols-[1.1fr_1fr] xl:grid-cols-[1.3fr_1fr]">
            <!-- LEFT — editorial/manifest side -->
            <section class="hidden lg:flex flex-col justify-between p-10 xl:p-14 border-r border-hairline relative">
                <!-- Document header -->
                <div class="space-y-7">
                    <div class="flex items-center gap-2 font-mono text-2xs uppercase tracking-[0.18em] text-muted">
                        <span class="w-6 h-px bg-muted/60"></span>
                        <span>Judicial Operations Platform</span>
                        <span>·</span>
                        <span class="text-primary font-semibold">LF-0001</span>
                    </div>

                    <h1 class="text-balance text-4xl xl:text-[3.4rem] font-semibold tracking-tight leading-[1.04] max-w-xl text-ink">
                        Secure case intelligence
                        <br/>for
                        <span class="relative inline-block">
                            <span class="text-primary">courts</span><span class="text-ink">, </span><span class="text-primary">counsel</span><span class="text-ink">,</span>
                        </span>
                        <br/>
                        <span class="text-ink">and</span>
                        <span class="text-primary">investigators</span><span class="text-ink">.</span>
                    </h1>

                    <p class="text-muted text-base max-w-md leading-relaxed">
                        Centralised filing, role-aware assignments, hearing schedules, and verdict workflows — with a complete audit trail on every action.
                    </p>
                </div>

                <!-- Live system strip — animated, makes the page feel alive -->
                <div class="mt-10 max-w-md">
                    <div class="flex items-center gap-2.5 font-mono text-2xs uppercase tracking-[0.16em] text-muted mb-3">
                        <span class="inline-flex w-1.5 h-1.5 rounded-full bg-success animate-pulse-dot"></span>
                        <span>Live · across jurisdictions</span>
                    </div>
                    <div class="lf-liquid lf-liquid-soft overflow-hidden">
                        <div class="grid grid-cols-3 divide-x divide-white/30 dark:divide-white/10">
                            <div class="p-4">
                                <div class="font-mono text-2xs uppercase tracking-wider text-muted">Open cases</div>
                                <div class="mt-1.5 font-mono text-2xl tabular-nums text-ink">2,481</div>
                                <div class="mt-1 flex items-center gap-1 text-2xs text-success">
                                    <LfIcon Name="trending-up" Size="11" />
                                    <span class="font-mono tabular-nums">+12 / 24h</span>
                                </div>
                            </div>
                            <div class="p-4">
                                <div class="font-mono text-2xs uppercase tracking-wider text-muted">Hearings today</div>
                                <div class="mt-1.5 font-mono text-2xl tabular-nums text-ink">36</div>
                                <div class="mt-1 text-2xs text-muted font-mono">across 8 courts</div>
                            </div>
                            <div class="p-4">
                                <div class="font-mono text-2xs uppercase tracking-wider text-muted">Verdicts MTD</div>
                                <div class="mt-1.5 font-mono text-2xl tabular-nums text-ink">128</div>
                                <div class="mt-1 flex items-center gap-1 text-2xs text-primary">
                                    <span class="font-mono tabular-nums">68% closed</span>
                                </div>
                            </div>
                        </div>
                        <div class="px-4 py-2.5 border-t border-white/30 dark:border-white/10 flex items-center justify-between">
                            <div class="font-mono text-2xs uppercase tracking-wider text-muted">case · LF-2481/Q · STATE v. AHMED</div>
                            <LfChip Tone="primary" Pulse="true">Hearing 14:30</LfChip>
                        </div>
                    </div>
                </div>

                <!-- Footer line -->
                <div class="mt-8 flex items-center justify-between text-2xs font-mono uppercase tracking-wider text-muted">
                    <span>Confidential · TLS 1.3</span>
                    <span class="flex items-center gap-1.5">
                        <LfIcon Name="shield" Size="12" /> session-bound · cookie-auth
                    </span>
                </div>
            </section>

            <!-- RIGHT — sign-in card -->
            <section class="flex items-center justify-center p-6 lg:p-10">
                <div class="w-full max-w-md">
                    <!-- Card stamp header -->
                    <div class="flex items-center justify-between mb-4">
                        <span class="font-mono text-2xs uppercase tracking-[0.16em] text-muted">FORM · AUTH-001</span>
                        <span class="font-mono text-2xs uppercase tracking-wider @StatusClass">
                            <span class="inline-block w-1.5 h-1.5 rounded-full @StatusDotClass mr-1.5 align-middle"></span>
                            @StatusText
                        </span>
                    </div>

                    <div class="lf-liquid lf-liquid-strong p-7">
                        <h2 class="text-xl font-semibold tracking-tight text-ink">Sign in</h2>
                        <p class="text-sm text-muted mt-1">Enter your credentials to continue.</p>

                        <EditForm Model="@_loginModel" OnValidSubmit="HandleLogin" class="mt-6 space-y-4">
                            <DataAnnotationsValidator />

                            <LfInput Label="Username"
                                     StartIcon="user"
                                     Placeholder="username"
                                     AutoComplete="username"
                                     Required
                                     @bind-Value="_loginModel.Username" />

                            <LfInput Label="Password"
                                     Type="@(_showPassword ? "text" : "password")"
                                     StartIcon="shield"
                                     EndIcon="@(_showPassword ? "eye-off" : "eye")"
                                     OnEndIconClick="TogglePasswordVisibility"
                                     Placeholder="••••••••••"
                                     AutoComplete="current-password"
                                     Required
                                     @bind-Value="_loginModel.Password" />

                            <LfButton Type="submit" Variant="primary" Size="lg" FullWidth Loading="_loading">
                                @if (_loading) { <span>Authenticating…</span> } else { <span>Sign in</span> }
                                @if (!_loading) { <LfIcon Name="arrow-right" Size="15" /> }
                            </LfButton>

                            @if (!string.IsNullOrEmpty(_errorMessage))
                            {
                                <div class="flex items-start gap-2 p-3 rounded-card border border-danger/30 bg-danger/8 text-sm">
                                    <LfIcon Name="alert-circle" Size="15" Class="text-danger mt-0.5" />
                                    <div>
                                        <div class="font-mono text-2xs uppercase tracking-wider text-danger">err · 401</div>
                                        <div class="text-ink mt-0.5">@_errorMessage</div>
                                    </div>
                                </div>
                            }
                        </EditForm>

                        <!-- Demo accounts panel -->
                        <div class="mt-7">
                            <div class="flex items-center gap-3">
                                <div class="flex-1 lf-rule"></div>
                                <span class="font-mono text-2xs uppercase tracking-wider text-muted">quick demo · pwd: Password123!</span>
                                <div class="flex-1 lf-rule"></div>
                            </div>

                            <div class="mt-4 grid grid-cols-3 gap-1.5">
                                @foreach (var demo in _demoUsers)
                                {
                                    <button type="button" @onclick="@(() => AutoFill(demo.username))"
                                            class="group lf-btn-outline !py-1.5 !px-2 flex-col items-center !gap-0.5">
                                        <span class="font-mono text-2xs text-muted uppercase tracking-wider group-hover:text-primary transition-colors">@demo.role</span>
                                        <span class="text-xs truncate w-full text-center">@demo.username</span>
                                    </button>
                                }
                            </div>
                        </div>
                    </div>

                    <!-- Tiny footnote -->
                    <p class="mt-5 text-center text-2xs font-mono uppercase tracking-wider text-muted">
                        All actions logged · ts @_now
                    </p>
                </div>
            </section>
        </div>
    </div>
</div>

@code {
    private LoginViewModel _loginModel = new();
    private bool _loading = false;
    private bool _showPassword = false;
    private string? _errorMessage;
    private string _now = DateTime.UtcNow.ToString("yyyy-MM-dd HH:mm 'UTC'");

    private readonly (string role, string username)[] _demoUsers = new[]
    {
        ("admin",  "admin"),
        ("judge",  "judge_ali"),
        ("lawyer", "lawyer_faisal"),
        ("client", "client_zaheer"),
        ("police", "police_rahim"),
        ("clerk",  "clerk_ahmad"),
    };

    private string StatusText  => _loading ? "AUTHENTICATING…" : (!string.IsNullOrEmpty(_errorMessage) ? "REJECTED" : "READY");
    private string StatusClass => _loading ? "text-info"   : (!string.IsNullOrEmpty(_errorMessage) ? "text-danger" : "text-muted");
    private string StatusDotClass => _loading ? "bg-info animate-pulse-dot" : (!string.IsNullOrEmpty(_errorMessage) ? "bg-danger" : "bg-success animate-pulse-dot");

    private void TogglePasswordVisibility() => _showPassword = !_showPassword;

    private void AutoFill(string username)
    {
        _loginModel.Username = username;
        _loginModel.Password = "Password123!";
        _errorMessage = null;
    }

    private async Task HandleLogin()
    {
        _loading = true;
        _errorMessage = null;
        try
        {
            var session = await AuthService.LoginAsync(_loginModel.Username, _loginModel.Password);
            if (session != null)
            {
                await CustomAuth.UpdateAuthenticationState(session);
                Toast.Success($"Welcome back, {session.FullName}");
                var roleRoute = string.IsNullOrWhiteSpace(session.Role) ? "client" : session.Role.ToLowerInvariant();
                Navigation.NavigateTo($"/{roleRoute}/dashboard", replace: true);
            }
            else
            {
                _errorMessage = "Invalid username or password.";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    public class LoginViewModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Username is required")]
        public string Username { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Password is required")]
        public string Password { get; set; } = string.Empty;
    }
}
