@page "/login"
@layout Layout.MainLayout
@inject AuthService AuthService
@inject CustomAuthenticationStateProvider CustomAuth
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>Sign In - LawFlow</PageTitle>

<div class="d-flex flex-column align-center justify-center lf-page-transition" style="min-height: 90vh; background: radial-gradient(circle at 10% 20%, rgba(30, 58, 138, 0.05) 0%, rgba(14, 165, 233, 0.05) 90.1%);">
    
    <!-- Branding Header -->
    <div class="d-flex align-center justify-center mb-6">
        <MudIcon Icon="@Icons.Material.Filled.Gavel" Color="Color.Primary" Size="Size.Large" Style="font-size: 40px;" />
        <MudText Typo="Typo.h4" Class="ml-2 font-weight-bold" Style="color: var(--lf-primary); font-weight: 800; letter-spacing: -0.5px;">
            Law<span style="color: #0EA5E9;">Flow</span>
        </MudText>
    </div>

    <!-- Login Glassmorphic Panel -->
    <div class="lf-glass-panel pa-8" style="width: 100%; max-width: 440px; border-radius: 20px;">
        <MudText Typo="Typo.h5" Class="font-weight-bold mb-1" Align="Align.Center">Welcome Back</MudText>
        <MudText Typo="Typo.body2" Class="text-muted mb-6" Align="Align.Center">Smart Judicial Case Management Platform</MudText>

        <EditForm Model="@_loginModel" OnValidSubmit="HandleLogin">
            <DataAnnotationsValidator />

            <MudTextField @bind-Value="_loginModel.Username" 
                          Label="Username" 
                          Variant="Variant.Outlined" 
                          Adornment="Adornment.Start" 
                          AdornmentIcon="@Icons.Material.Filled.Person"
                          For="@(() => _loginModel.Username)" 
                          Class="mb-4" />

            <MudTextField @bind-Value="_loginModel.Password" 
                          Label="Password" 
                          Variant="Variant.Outlined" 
                          InputType="@_passwordInput" 
                          Adornment="Adornment.End" 
                          AdornmentIcon="@_passwordInputIcon"
                          OnAdornmentClick="TogglePasswordVisibility"
                          For="@(() => _loginModel.Password)"
                          Class="mb-6" />

            <MudButton ButtonType="ButtonType.Submit" 
                       Variant="Variant.Filled" 
                       Color="Color.Primary" 
                       FullWidth="true" 
                       Size="Size.Large"
                       Style="border-radius: 10px; height: 50px; text-transform: none; font-weight: 600;"
                       Disabled="@_loading">
                @if (_loading)
                {
                    <MudProgressCircular Color="Color.Secondary" Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    <span>Signing in...</span>
                }
                else
                {
                    <span>Sign In</span>
                }
            </MudButton>
        </EditForm>
    </div>

    <!-- Quick Demo Accounts Seeding Helper -->
    <div class="mt-6 pa-6 lf-glass-panel" style="width: 100%; max-width: 700px; border-radius: 16px;">
        <MudText Typo="Typo.subtitle2" Class="font-weight-bold mb-3" Align="Align.Center">
            <MudIcon Icon="@Icons.Material.Filled.Bolt" Color="Color.Warning" Size="Size.Small" Class="mr-1" />
            Quick Demo One-Click Sign In (Password: Password123!)
        </MudText>
        <MudGrid Spacing="2" Justify="Justify.Center">
            <MudItem xs="4" sm="2">
                <MudButton FullWidth="true" Variant="Variant.Outlined" Size="Size.Small" Color="Color.Primary" Style="border-radius: 8px; text-transform:none;" OnClick='() => AutoFill("admin")'>Admin</MudButton>
            </MudItem>
            <MudItem xs="4" sm="2">
                <MudButton FullWidth="true" Variant="Variant.Outlined" Size="Size.Small" Color="Color.Primary" Style="border-radius: 8px; text-transform:none;" OnClick='() => AutoFill("judge_ali")'>Judge</MudButton>
            </MudItem>
            <MudItem xs="4" sm="2">
                <MudButton FullWidth="true" Variant="Variant.Outlined" Size="Size.Small" Color="Color.Primary" Style="border-radius: 8px; text-transform:none;" OnClick='() => AutoFill("lawyer_faisal")'>Lawyer</MudButton>
            </MudItem>
            <MudItem xs="4" sm="2">
                <MudButton FullWidth="true" Variant="Variant.Outlined" Size="Size.Small" Color="Color.Primary" Style="border-radius: 8px; text-transform:none;" OnClick='() => AutoFill("client_zaheer")'>Client</MudButton>
            </MudItem>
            <MudItem xs="4" sm="2">
                <MudButton FullWidth="true" Variant="Variant.Outlined" Size="Size.Small" Color="Color.Primary" Style="border-radius: 8px; text-transform:none;" OnClick='() => AutoFill("police_rahim")'>Police</MudButton>
            </MudItem>
            <MudItem xs="4" sm="2">
                <MudButton FullWidth="true" Variant="Variant.Outlined" Size="Size.Small" Color="Color.Primary" Style="border-radius: 8px; text-transform:none;" OnClick='() => AutoFill("clerk_ahmad")'>Clerk</MudButton>
            </MudItem>
        </MudGrid>
    </div>
</div>

@code {
    private LoginViewModel _loginModel = new();
    private bool _loading = false;
    private bool _showPassword = false;
    private InputType _passwordInput = InputType.Password;
    private string _passwordInputIcon = Icons.Material.Filled.VisibilityOff;

    private void TogglePasswordVisibility()
    {
        _showPassword = !_showPassword;
        _passwordInput = _showPassword ? InputType.Text : InputType.Password;
        _passwordInputIcon = _showPassword ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff;
    }

    private void AutoFill(string username)
    {
        _loginModel.Username = username;
        _loginModel.Password = "Password123!";
    }

    private async Task HandleLogin()
    {
        _loading = true;
        try
        {
            var session = await AuthService.LoginAsync(_loginModel.Username, _loginModel.Password);
            if (session != null)
            {
                await CustomAuth.UpdateAuthenticationState(session);
                Snackbar.Add($"Logged in successfully as {session.FullName}", Severity.Success);
                Navigation.NavigateTo("/dashboard");
            }
            else
            {
                Snackbar.Add("Invalid username or password.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Login failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    public class LoginViewModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Username is required")]
        public string Username { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Password is required")]
        public string Password { get; set; } = string.Empty;
    }
}
