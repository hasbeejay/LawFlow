@page "/police/registry"
@attribute [Authorize(Roles = "Police")]
@inject CaseService CaseService
@inject PoliceReportService PoliceReportService
@inject VerdictService VerdictService
@inject AuthenticationStateProvider AuthStateProvider
@inject ISnackbar Snackbar
@inject IJSRuntime JS
@using System.Security.Claims
@using System.Text
@using LawFlow.Models

<PageTitle>Criminal Record Registrar - LawFlow</PageTitle>

<div class="lf-page-transition">
    <div class="d-flex flex-column flex-sm-row justify-space-between align-start align-sm-center mb-6">
        <div>
            <MudText Typo="Typo.h4" Class="font-weight-bold" Style="color: var(--lf-primary); font-weight: 700;">
                Criminal Certificate Registry
            </MudText>
            <MudText Typo="Typo.body2" Class="text-muted mt-1">Check and balance criminal data logs, print official conviction certificates, and clear logs of cleared individuals.</MudText>
        </div>
    </div>

    @if (_loading)
    {
        <div class="d-flex justify-center py-10">
            <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
        </div>
    }
    else
    {
        <MudGrid>
            <!-- Registry Statistics -->
            <MudItem xs="12" sm="4">
                <MudPaper Class="pa-4 lf-glow-card" Style="background: linear-gradient(135deg, #1E293B 0%, #0F172A 100%); color: white;">
                    <MudText Typo="Typo.subtitle2" Class="font-weight-bold opacity-75">Core Docket Archives</MudText>
                    <MudText Typo="Typo.h3" Class="font-weight-bold mt-1">@_closedCases.Count</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudPaper Class="pa-4 lf-glow-card" Style="background: white; border-left: 5px solid #EF4444;">
                    <MudText Typo="Typo.subtitle2" Class="text-muted font-weight-bold">Active Criminal Certificates (Guilty)</MudText>
                    <MudText Typo="Typo.h3" Class="font-weight-bold mt-1 text-danger">@_closedCases.Count(c => c.Verdict?.Type == VerdictType.Guilty)</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudPaper Class="pa-4 lf-glow-card" Style="background: white; border-left: 5px solid #10B981;">
                    <MudText Typo="Typo.subtitle2" Class="text-muted font-weight-bold">Cleared Certificate Logs (Acquitted/Dismissed)</MudText>
                    <MudText Typo="Typo.h3" Class="font-weight-bold mt-1 text-success">@_closedCases.Count(c => c.Verdict?.Type != VerdictType.Guilty)</MudText>
                </MudPaper>
            </MudItem>

            <!-- Cases Grid Table -->
            <MudItem xs="12">
                <MudPaper Class="pa-6 lf-glass-panel" Style="border-radius: 16px;">
                    <div class="d-flex justify-space-between align-center mb-4">
                        <MudText Typo="Typo.h6" Class="font-weight-bold">National Conviction Logs</MudText>
                        <MudTextField @bind-Value="_searchQuery" 
                                       Label="Search citizen name or case..." 
                                       Variant="Variant.Outlined" 
                                       Adornment="Adornment.Start" 
                                       AdornmentIcon="@Icons.Material.Filled.Search"
                                       Immediate="true"
                                       OnKeyUp="FilterCases"
                                       Margin="Margin.Dense"
                                       Style="max-width: 300px; background: white;" />
                    </div>

                    <MudTable Items="@_filteredCases" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="0" Style="background:transparent;">
                        <HeaderContent>
                            <MudTh>Case Number</MudTh>
                            <MudTh>Accused Citizen</MudTh>
                            <MudTh>Incident Description</MudTh>
                            <MudTh>Verdict Determination</MudTh>
                            <MudTh>Log Certificate Status</MudTh>
                            <MudTh Style="text-align: right;">Judicial Actions</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Case Number">
                                <MudChip T="string" Color="Color.Dark" Variant="Variant.Outlined" Size="Size.Small" Style="font-weight:600; border-radius:6px;">
                                    @context.CaseNumber
                                </MudChip>
                            </MudTd>
                            <MudTd DataLabel="Accused Citizen" Style="font-weight:600;">@context.Client?.FullName</MudTd>
                            <MudTd DataLabel="Incident Description">@context.Title</MudTd>
                            <MudTd DataLabel="Verdict Determination">
                                @if (context.Verdict != null)
                                {
                                    <MudChip T="string" Color="@GetVerdictColor(context.Verdict.Type)" Size="Size.Small" Style="font-weight:600; border-radius:6px;">
                                        @context.Verdict.Type.ToString()
                                    </MudChip>
                                }
                                else
                                {
                                    <span class="text-muted">No Verdict Record</span>
                                }
                            </MudTd>
                            <MudTd DataLabel="Log Certificate Status">
                                @if (context.Verdict?.Type == VerdictType.Guilty)
                                {
                                    <span class="d-flex align-center gap-1 font-weight-bold text-danger">
                                        <span class="lf-pulse-badge mr-2"></span>
                                        Criminal Record Active
                                    </span>
                                }
                                else
                                {
                                    <span class="d-flex align-center gap-1 font-weight-bold text-success">
                                        <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
                                        Clear Record Log
                                    </span>
                                }
                            </MudTd>
                            <MudTd Style="text-align: right;">
                                <div class="d-flex justify-end gap-2">
                                    @if (context.Verdict?.Type == VerdictType.Guilty)
                                    {
                                        <MudButton Variant="Variant.Filled" 
                                                   Color="Color.Error" 
                                                   Size="Size.Small" 
                                                   StartIcon="@Icons.Material.Filled.Print" 
                                                   OnClick="() => HandleDownloadCertificate(context)" 
                                                   Style="border-radius:6px; text-transform:none;">
                                            Print Certificate
                                        </MudButton>
                                    }
                                    else
                                    {
                                        <MudButton Variant="Variant.Outlined" 
                                                   Color="Color.Success" 
                                                   Size="Size.Small" 
                                                   StartIcon="@Icons.Material.Filled.DeleteSweep" 
                                                   OnClick="() => HandlePurgeLog(context)" 
                                                   Style="border-radius:6px; text-transform:none;">
                                            Purge Log
                                        </MudButton>
                                    }
                                    <MudButton Href="@($"/cases/view/{context.Id}")" Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small" Style="border-radius:6px; text-transform:none;">
                                        Open Case File
                                    </MudButton>
                                </div>
                            </MudTd>
                        </RowTemplate>
                        <PagerContent>
                            <MudTablePager PageSizeOptions="new int[]{10, 25, 50}" />
                        </PagerContent>
                    </MudTable>
                </MudPaper>
            </MudItem>
        </MudGrid>
    }
</div>

@code {
    private bool _loading = true;
    private string _searchQuery = string.Empty;
    private string _userId = string.Empty;
    private List<Case> _closedCases = new();
    private List<Case> _filteredCases = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadRegistry();
    }

    private async Task LoadRegistry()
    {
        _loading = true;

        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        _userId = auth.User.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? "";

        // Only show closed cases this officer was assigned to.
        var mine = await CaseService.GetCasesForUserAsync(_userId, UserRole.Police);
        _closedCases = mine.Where(c => c.Status == CaseStatus.Closed).ToList();

        // GetCasesForUserAsync doesn't include Verdict; hydrate it for our list.
        var verdicts = (await VerdictService.GetAllVerdictsAsync())
            .GroupBy(v => v.CaseId)
            .ToDictionary(g => g.Key, g => g.First());
        foreach (var c in _closedCases)
        {
            if (verdicts.TryGetValue(c.Id, out var v)) c.Verdict = v;
        }

        FilterCases();
        _loading = false;
    }

    private void FilterCases()
    {
        if (string.IsNullOrEmpty(_searchQuery))
        {
            _filteredCases = _closedCases;
        }
        else
        {
            var txt = _searchQuery.ToLower();
            _filteredCases = _closedCases.Where(c => 
                c.CaseNumber.ToLower().Contains(txt) || 
                c.Title.ToLower().Contains(txt) ||
                (c.Client != null && c.Client.FullName.ToLower().Contains(txt))
            ).ToList();
        }
    }

    private async Task HandleDownloadCertificate(Case c)
    {
        var html = BuildCertificateHtml(c);
        var bytes = Encoding.UTF8.GetBytes(html);
        var base64 = Convert.ToBase64String(bytes);
        var fileName = $"criminal-certificate-{c.CaseNumber}.html";
        // download via dynamically created anchor on the client
        await JS.InvokeVoidAsync("eval", $@"
            (function(){{
                const a = document.createElement('a');
                a.href = 'data:text/html;base64,{base64}';
                a.download = '{fileName}';
                document.body.appendChild(a);
                a.click();
                a.remove();
            }})();
        ");
        Snackbar.Add($"Certificate exported for {c.Client?.FullName} ({c.CaseNumber}).", Severity.Success);
    }

    private async Task HandlePurgeLog(Case c)
    {
        var ok = await PoliceReportService.ClearCriminalRecordAsync(c.Id, _userId);
        if (ok) Snackbar.Add($"Criminal record cleared for {c.Client?.FullName} in case {c.CaseNumber}.", Severity.Success);
        else Snackbar.Add("Could not clear record (not your case?).", Severity.Error);
        await LoadRegistry();
    }

    private static string BuildCertificateHtml(Case c)
    {
        var verdictType = c.Verdict?.Type.ToString() ?? "—";
        var verdictDetails = c.Verdict?.Details ?? "";
        var issuedAt = c.Verdict?.IssuedAt.ToString("yyyy-MM-dd") ?? "—";
        var accused = c.Client?.FullName ?? "—";
        var judge = c.Judge?.FullName ?? "—";
        return $@"<!doctype html>
<html><head><meta charset='utf-8'><title>Criminal Conviction Certificate · {c.CaseNumber}</title>
<style>
  body {{ font-family: 'Georgia', serif; max-width: 780px; margin: 40px auto; padding: 40px; color: #111; }}
  h1 {{ font-size: 22px; letter-spacing: 4px; text-transform: uppercase; text-align: center; }}
  .subtitle {{ text-align: center; color: #666; letter-spacing: 2px; text-transform: uppercase; font-size: 11px; }}
  .border {{ border: 2px solid #111; padding: 32px; }}
  .row {{ display: grid; grid-template-columns: 180px 1fr; gap: 12px; padding: 8px 0; border-bottom: 1px solid #eee; }}
  .label {{ font-weight: 700; text-transform: uppercase; font-size: 11px; letter-spacing: 1px; color: #555; }}
  .seal {{ margin-top: 36px; text-align: center; font-size: 12px; color: #555; }}
</style></head>
<body>
  <div class='border'>
    <div class='subtitle'>LawFlow · Judicial Operations</div>
    <h1>Criminal Conviction Certificate</h1>
    <div class='row'><div class='label'>Case Number</div><div>{c.CaseNumber}</div></div>
    <div class='row'><div class='label'>Accused</div><div>{accused}</div></div>
    <div class='row'><div class='label'>Charge / Title</div><div>{c.Title}</div></div>
    <div class='row'><div class='label'>Verdict</div><div>{verdictType}</div></div>
    <div class='row'><div class='label'>Reasoning</div><div>{verdictDetails}</div></div>
    <div class='row'><div class='label'>Presiding Judge</div><div>{judge}</div></div>
    <div class='row'><div class='label'>Issued</div><div>{issuedAt}</div></div>
    <div class='seal'>This certificate is generated from the LawFlow audit trail and is valid pending verification with the court of record.</div>
  </div>
</body></html>";
    }

    private Color GetVerdictColor(VerdictType type)
    {
        return type switch
        {
            VerdictType.Guilty => Color.Error,
            VerdictType.Acquitted => Color.Success,
            VerdictType.Dismissed => Color.Info,
            VerdictType.Appealed => Color.Warning,
            _ => Color.Default
        };
    }
}
