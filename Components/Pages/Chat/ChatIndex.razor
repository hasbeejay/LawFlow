@page "/chat"
@attribute [Authorize(Roles = "Admin,Judge,Lawyer,Client,Police,Clerk")]
@inject MessageService MessageService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation

<PageTitle>Chat — LawFlow</PageTitle>

<div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-6">
    <div>
        <div class="font-mono text-2xs uppercase tracking-[0.18em] text-muted flex items-center gap-2">
            <span class="w-6 h-px bg-muted/60"></span>
            <span>Secure consultation · @_channelLabel</span>
        </div>
        <h1 class="mt-1.5 text-2xl md:text-3xl font-semibold tracking-tight text-balance">Chat with @_pairLabel</h1>
        <p class="mt-1 text-sm text-muted">Pick a case to enter its private chat room. You can only see messages from your own channel.</p>
    </div>
</div>

@if (_loading)
{
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        @for (int i = 0; i < 6; i++)
        {
            <div class="lf-card p-5 animate-pulse flex flex-col h-full w-full justify-between gap-4">
                <div class="flex flex-col gap-3 w-full">
                    <div class="flex items-center justify-between w-full">
                        <div class="h-5 w-16 bg-hairline rounded-xs"></div>
                        <div class="h-5 w-24 bg-hairline rounded-full"></div>
                    </div>
                    <div>
                        <div class="h-5 w-3/4 bg-hairline rounded-xs mb-2"></div>
                        <div class="h-3 w-full bg-hairline/60 rounded-xs mb-1.5"></div>
                        <div class="h-3 w-4/5 bg-hairline/60 rounded-xs"></div>
                    </div>
                </div>
                <div class="mt-2 pt-3 border-t border-hairline/50 flex items-center justify-between w-full">
                    <div class="h-4 w-24 bg-hairline/60 rounded-xs"></div>
                    <div class="h-4 w-16 bg-hairline/40 rounded-xs"></div>
                </div>
            </div>
        }
    </div>
}
else if (_cases.Count == 0)
{
    <div class="lf-card p-10 text-center">
        <div class="inline-flex items-center justify-center w-12 h-12 rounded-card bg-canvas border border-hairline text-muted">
            <LfIcon Name="message-circle" Size="20" />
        </div>
        <div class="mt-3 text-sm text-muted">You have no cases that allow chat in your channel yet.</div>
    </div>
}
else
{
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        @foreach (var c in _cases)
        {
            <button type="button" @onclick="@(() => Open(c.Id))"
                    class="lf-card p-5 text-left flex flex-col h-full w-full justify-between gap-4 transition transform hover:-translate-y-1 hover:shadow-sm dark:hover:shadow-sm hover:border-primary/40 z-10 relative">
                <div class="flex flex-col gap-3 w-full">
                    <div class="flex items-center justify-between w-full">
                        <span class="lf-tag-num border-transparent bg-canvas/50">@c.CaseNumber</span>
                        <LfStatusChip Status="@c.Status" />
                    </div>
                    <div>
                        <h3 class="font-semibold text-ink line-clamp-1 group-hover:text-primary transition-colors text-base tracking-tight">@c.Title</h3>
                        <p class="mt-1.5 text-xs text-muted line-clamp-2 leading-relaxed">@c.Description</p>
                    </div>
                </div>
                <div class="mt-2 pt-3 border-t border-hairline/50 flex items-center justify-between font-mono text-2xs text-muted w-full">
                    <span class="px-2 py-1 rounded-sm bg-canvas/60">@(_role) ↔ @_otherRole</span>
                    <span class="text-primary font-medium opacity-0 -translate-x-2 group-hover:translate-x-0 group-hover:opacity-100 transition-all duration-200">Open chat &rarr;</span>
                </div>
            </button>
        }
    </div>
}

@code {
    private bool _loading = true;
    private string _role = string.Empty;
    private string _userId = string.Empty;
    private string _channelLabel = "";
    private string _pairLabel = "";
    private string _otherRole = "";
    private List<Case> _cases = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var auth = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = auth.User;
            if (!(user.Identity?.IsAuthenticated ?? false)) return;

            _role = user.FindFirst(ClaimTypes.Role)?.Value ?? "";
            _userId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? "";

            var channel = MessageService.GetChannelForRole(_role);
            if (channel == null)
            {
                _cases = new();
                return;
            }

            (_channelLabel, _pairLabel, _otherRole) = channel.Value switch
            {
                ChatChannel.ClientLawyer => ("Client ↔ Lawyer",  _role == "Client" ? "your lawyer" : "your clients", _role == "Client" ? "Lawyer" : "Client"),
                ChatChannel.JudgeClerk   => ("Judge ↔ Clerk",    _role == "Judge"  ? "your clerk"  : "your judge",   _role == "Judge"  ? "Clerk"  : "Judge"),
                ChatChannel.AdminPolice  => ("Admin ↔ Police",   _role == "Admin"  ? "police officers" : "administration", _role == "Admin" ? "Police" : "Admin"),
                _ => ("", "", "")
            };

            _cases = await MessageService.GetCasesForChatAsync(_userId, _role);
        }
        finally
        {
            _loading = false;
        }
    }

    private void Open(int caseId) => Navigation.NavigateTo($"/chat/{caseId}");
}
