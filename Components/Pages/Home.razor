@page "/"
@layout Layout.MainLayout

<PageTitle>LawFlow — Judicial Operations Platform</PageTitle>

<style>
  .hero-title {
    font-size: 3.5rem;
    line-height: 1.1;
    font-weight: 900;
  }
  @@media (min-width: 1024px) {
    .hero-title {
      font-size: 5.5rem;
    }
  }
  .gradient-text {
    background: linear-gradient(to right, rgb(var(--lf-primary)), #7C5CFA, #E5B64E);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .primary-glow-btn {
    background: linear-gradient(135deg, rgb(var(--lf-primary)), #7C5CFA);
    color: white !important;
    padding: 1.25rem 2.5rem;
    border-radius: 1rem;
    font-weight: bold;
    font-size: 1.125rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 10px 25px rgba(91, 60, 222, 0.4);
    transition: all 0.3s ease;
    border: none;
    text-decoration: none;
  }
  .primary-glow-btn:hover {
    transform: scale(1.05);
    box-shadow: 0 15px 35px rgba(91, 60, 222, 0.6);
  }
  .github-btn {
    padding: 1.25rem 2.5rem;
    border-radius: 1rem;
    font-weight: 600;
    font-size: 1.125rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgb(var(--lf-hairline));
    transition: all 0.3s ease;
    background: rgb(var(--lf-surface) / 0.5);
    backdrop-filter: blur(10px);
    text-decoration: none;
    color: inherit;
  }
  .github-btn:hover {
    background: rgb(var(--lf-surface));
    border-color: rgb(var(--lf-primary) / 0.4);
  }



  /* Ambient Glows */
  .ambient-primary {
    position: absolute; top: -10%; left: 10%; width: 40%; height: 40%; border-radius: 50%;
    background-color: rgba(91, 60, 222, 0.15); filter: blur(100px); pointer-events: none;
  }
  .ambient-gold {
    position: absolute; bottom: 20%; right: 5%; width: 30%; height: 40%; border-radius: 50%;
    background-color: rgba(229, 182, 78, 0.1); filter: blur(100px); pointer-events: none;
  }
</style>

<div class="min-h-dvh w-full bg-canvas relative overflow-x-hidden selection:bg-primary/30 flex flex-col font-sans text-ink">
    
    <!-- Background aesthetics -->
    <div class="absolute inset-0 grid-bg opacity-40 pointer-events-none"></div>
    <div class="ambient-primary animate-pulse" style="animation-duration: 8s;"></div>
    <div class="ambient-gold animate-pulse" style="animation-duration: 10s;"></div>

    <!-- Header -->
    <header class="w-full h-16 px-6 lg:px-12 flex items-center justify-between border-b border-hairline bg-surface/50 backdrop-blur-xl z-50 sticky top-0">
        <LfBrand Href="/" />
        <div class="flex items-center gap-6">
            <span class="hidden md:inline-flex items-center gap-1.5 font-mono text-xs text-muted uppercase tracking-wider bg-canvas/50 px-3 py-1 rounded-full border border-hairline shadow-sm">
                <span class="w-2 h-2 rounded-full bg-success animate-pulse-dot"></span>
                System Online
            </span>
            <LfThemeToggle />
        </div>
    </header>

    <!-- Hero Section -->
    <main class="flex-1 w-full max-w-[1400px] mx-auto px-6 lg:px-16 pt-16 pb-24 z-10">
        
        <div class="grid grid-cols-1 lg:grid-cols-2 items-center" style="gap: 4rem; margin-bottom: 8rem;">
            <!-- Left Content -->
            <div class="flex flex-col items-start text-left animate-fade-in-up">
                
                <div class="inline-flex items-center gap-3 px-4 py-1.5 rounded-full border border-primary/20 bg-primary/10 backdrop-blur-md shadow-[0_0_15px_rgba(91,60,222,0.15)]" style="margin-bottom: 2rem;">
                    <LfIcon Name="shield" Size="14" Class="text-primary" />
                    <span class="font-mono text-xs uppercase tracking-widest text-primary font-bold">Secure Gateway</span>
                </div>

                <h1 class="hero-title text-ink drop-shadow-sm" style="margin-bottom: 1.5rem;">
                    Welcome to<br/>
                    <span class="gradient-text">LawFlow</span>
                </h1>

                <p class="text-muted text-xl leading-relaxed max-w-lg" style="margin-bottom: 3rem;">
                    The next-generation judicial operations platform. Unifying case filings, evidence, hearings, and verdicts with immutable audit trails.
                </p>

                <div class="flex flex-col sm:flex-row items-center w-full sm:w-auto" style="gap: 1.25rem;">
                    <a href="/login" class="primary-glow-btn w-full sm:w-auto group">
                        Access Dashboard
                        <LfIcon Name="arrow-right" Size="18" Class="ml-2 transition-transform group-hover:translate-x-1" />
                    </a>
                    
                    <a href="https://github.com/hasbeejay/LawFlow" target="_blank" rel="noopener noreferrer" class="github-btn w-full sm:w-auto">
                        <LfIcon Name="github" Size="18" Class="mr-2" />
                        Source Code
                    </a>
                </div>
            </div>

            <!-- Right Illustration -->
            <div class="relative flex justify-center lg:justify-end animate-fade-in-up" style="animation-delay: 200ms;">
                <img src="/images/law_illustration_transparent.png" alt="Law and Justice" class="relative z-10 w-full max-w-md lg:max-w-lg object-contain drop-shadow-2xl hover:-translate-y-1 transition-transform duration-200 ease-out" />
            </div>
        </div>


    </main>

    <!-- Footer -->
    <footer class="w-full py-8 border-t border-hairline/50 flex flex-col items-center justify-center text-sm text-muted bg-surface/30 backdrop-blur-xl mt-auto z-20">
        <div class="flex items-center gap-2 mb-3">
            <LfIcon Name="scale" Size="16" Class="text-primary" />
            <span class="font-bold text-ink text-base">LawFlow</span>
            <span class="mx-2 text-hairline">|</span>
            <span>Judicial Operations</span>
        </div>
        <div class="text-center">
            Developed by <span class="font-semibold text-ink">Haseeb Jalil</span>
            <br/>
            <a href="https://github.com/hasbeejay" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 mt-2 text-primary hover:text-[#7C5CFA] transition-colors font-mono text-xs border border-primary/20 px-3 py-1 rounded-full bg-primary/5 hover:bg-primary/10">
                <LfIcon Name="github" Size="12" />
                github.com/hasbeejay
            </a>
        </div>
    </footer>
</div>
