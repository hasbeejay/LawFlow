@page "/dashboard"
@page "/admin/dashboard"
@page "/lawyer/dashboard"
@page "/client/dashboard"
@page "/judge/dashboard"
@page "/police/dashboard"
@page "/clerk/dashboard"
@attribute [Authorize]
@inject DashboardService DashboardService
@inject CaseService CaseService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject ToastService Toast

<PageTitle>Dashboard — LawFlow</PageTitle>

<!-- HEADER STRIP -->
<div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-6">
    <div>
        <div class="font-mono text-2xs uppercase tracking-[0.18em] text-muted flex items-center gap-2">
            <span class="w-6 h-px bg-muted/60"></span>
            <span>Dashboard · @_role</span>
            <span class="text-primary">@(DateTime.UtcNow.ToString("yyyy-MM-dd"))</span>
        </div>
        <h1 class="mt-1.5 text-2xl md:text-3xl font-semibold tracking-tight text-balance">
            @Greeting, @_fullName.
        </h1>
        <p class="mt-1 text-sm text-muted">@_subtitle</p>
    </div>

    <div class="flex flex-wrap items-center gap-2">
        @if (_role == "Client")
        {
            <LfButton Href="/cases" Variant="primary" Icon="plus">Submit New FIR</LfButton>
        }
        @if (_role == "Clerk" || _role == "Admin")
        {
            <LfButton Href="/hearings" Variant="primary" Icon="calendar">Schedule Hearing</LfButton>
        }
        @if (_role == "Admin")
        {
            <LfButton Href="/admin/users" Variant="outline" Icon="users">Manage Accounts</LfButton>
        }
        <LfButton Href="/cases" Variant="outline" Icon="folder-open">Case Records</LfButton>
    </div>
</div>

@if (_loading)
{
    <!-- Skeleton state -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        @for (int i = 0; i < 4; i++)
        {
            <div class="lf-card p-5 animate-pulse">
                <div class="h-3 w-24 bg-hairline rounded-xs"></div>
                <div class="mt-4 h-8 w-20 bg-hairline rounded-xs"></div>
                <div class="mt-3 h-2.5 w-full bg-hairline/60 rounded-xs"></div>
            </div>
        }
    </div>
}
else
{
    <!-- KPI GRID — role aware -->
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4 mb-6">
        @if (_role == "Admin" && _adminStats != null)
        {
            <LfKpi Label="Total Cases"        Value="@(_adminStats.TotalCases.ToString("N0"))"        Icon="folder-open" Sparkline="@_trends?.CasesFiled"  Hint="all jurisdictions" />
            <LfKpi Label="Pending Review"     Value="@(_adminStats.PendingReview.ToString("N0"))"     Icon="alert-circle" Hint="awaiting admin" />
            <LfKpi Label="Investigations"     Value="@(_adminStats.ActiveInvestigations.ToString("N0"))" Icon="shield" Hint="active" />
            <LfKpi Label="In Hearings"        Value="@(_adminStats.ActiveHearings.ToString("N0"))"    Icon="scale" Hint="courtroom-bound" />
            <LfKpi Label="Closed Cases"       Value="@(_adminStats.ClosedCases.ToString("N0"))"       Icon="check-circle" Sparkline="@_trends?.CasesClosed" Hint="archived" />
            <LfKpi Label="Active Staff"       Value="@(_adminStats.ActiveUsers.ToString("N0"))"       Icon="users" Hint="signed-in users" />
        }
        else if (_role == "Judge" && _judgeStats != null)
        {
            <LfKpi Label="Assigned Cases"     Value="@(_judgeStats.TotalAssigned.ToString("N0"))"     Icon="scale" Sparkline="@_trends?.CasesFiled" Class="lg:col-span-2" />
            <LfKpi Label="Verdict Pending"    Value="@(_judgeStats.VerdictPending.ToString("N0"))"    Icon="alert-circle" />
            <LfKpi Label="Scheduled Hearings" Value="@(_judgeStats.ScheduledHearings.ToString("N0"))" Icon="calendar" />
            <LfKpi Label="Closed"             Value="@(_judgeStats.ClosedCases.ToString("N0"))"       Icon="check-circle" Sparkline="@_trends?.CasesClosed" Class="lg:col-span-2" />
        }
        else if (_role == "Lawyer" && _lawyerStats != null)
        {
            <LfKpi Label="Active Clients"     Value="@(_lawyerStats.ActiveCases.ToString("N0"))"      Icon="briefcase" Sparkline="@_trends?.CasesFiled" />
            <LfKpi Label="Resolved Cases"     Value="@(_lawyerStats.CompletedCases.ToString("N0"))"   Icon="check-circle" />
            <LfKpi Label="Upcoming Hearings"  Value="@(_lawyerStats.UpcomingHearings.ToString("N0"))" Icon="calendar" />
            <LfKpi Label="Cases Offered"      Value="@(_lawyerStats.OfferedCases.ToString("N0"))"     Icon="bell" Hint="awaiting your acceptance" />
        }
        else if (_role == "Client" && _clientStats != null)
        {
            <LfKpi Label="My Lodged Cases"    Value="@(_clientStats.TotalCases.ToString("N0"))"       Icon="folder-open" Class="col-span-2 sm:col-span-1" />
            <LfKpi Label="Active"             Value="@(_clientStats.ActiveCases.ToString("N0"))"      Icon="circle-dot" />
            <LfKpi Label="Closed"             Value="@(_clientStats.ClosedCases.ToString("N0"))"      Icon="check-circle" />
        }
        else if (_role == "Police" && _policeStats != null)
        {
            <LfKpi Label="Investigation Queue" Value="@(_policeStats.TotalAssigned.ToString("N0"))"    Icon="shield" Class="col-span-2 sm:col-span-1" />
            <LfKpi Label="Active Cases"        Value="@(_policeStats.UnderInvestigation.ToString("N0"))" Icon="circle-dot" />
            <LfKpi Label="Reports Filed"       Value="@(_policeStats.ReportsSubmitted.ToString("N0"))" Icon="file-text" />
        }
        else if (_role == "Clerk" && _clerkStats != null)
        {
            <LfKpi Label="Assigned Cases"      Value="@(_clerkStats.TotalAssigned.ToString("N0"))"     Icon="folder-open" Class="col-span-2 sm:col-span-1" />
            <LfKpi Label="Scheduled Hearings"  Value="@(_clerkStats.ScheduledHearings.ToString("N0"))" Icon="calendar" />
            <LfKpi Label="Pending Verdicts"    Value="@(_clerkStats.PendingVerdicts.ToString("N0"))"   Icon="file-text" Hint="awaiting publication" />
        }
    </div>

    @if ((_role == "Admin" || _role == "Judge" || _role == "Lawyer") && _trends != null && _verdicts != null)
    {
        <!-- CHART ROW -->
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-4 mb-6">
            <LfCard Class="lg:col-span-8">
                <Header>
                    <div>
                        <div class="font-mono text-2xs uppercase tracking-wider text-muted">Annual analytics</div>
                        <div class="text-base font-semibold mt-0.5">Case filings vs closures</div>
                    </div>
                </Header>
                <HeaderActions>
                    <LfChip Tone="neutral" ShowDot="false">@DateTime.UtcNow.Year</LfChip>
                </HeaderActions>
                <ChildContent>
                    <LfLineChart SeriesA="@_trends.CasesFiled"
                                 SeriesB="@_trends.CasesClosed"
                                 Labels="@_trends.Months"
                                 LabelA="Filed"
                                 LabelB="Closed"
                                 Height="240" />
                </ChildContent>
            </LfCard>

            <LfCard Class="lg:col-span-4">
                <Header>
                    <div>
                        <div class="font-mono text-2xs uppercase tracking-wider text-muted">Verdicts</div>
                        <div class="text-base font-semibold mt-0.5">Outcome distribution</div>
                    </div>
                </Header>
                <ChildContent>
                    <LfDonutChart CenterLabel="verdicts" Size="150" Slices="@_verdictSlices" />
                </ChildContent>
            </LfCard>
        </div>
    }

    <!-- RECENT CASES -->
    <LfCard Padding="false">
        <Header>
            <div class="p-5">
                <div class="font-mono text-2xs uppercase tracking-wider text-muted">Activity</div>
                <div class="text-base font-semibold mt-0.5">Recent case files</div>
            </div>
        </Header>
        <HeaderActions>
            <div class="p-5">
                <LfButton Href="/cases" Variant="ghost" Size="sm" EndIcon="arrow-right">View all</LfButton>
            </div>
        </HeaderActions>
        <ChildContent>
            @if (_recentCases.Count == 0)
            {
                <div class="px-6 py-14 text-center">
                    <div class="inline-flex items-center justify-center w-12 h-12 rounded-card bg-canvas border border-hairline text-muted">
                        <LfIcon Name="folder-open" Size="20" />
                    </div>
                    <div class="mt-3 text-sm text-muted">No case files yet.</div>
                </div>
            }
            else
            {
                <div class="overflow-x-auto">
                    <table class="lf-table">
                        <thead>
                            <tr>
                                <th class="w-44">Case</th>
                                <th>Title</th>
                                <th class="hidden md:table-cell">Client</th>
                                <th>Status</th>
                                <th class="hidden sm:table-cell">Filed</th>
                                <th class="w-20 text-right pr-5">—</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var c in _recentCases)
                            {
                                <tr>
                                    <td class="pl-5">
                                        <span class="lf-tag-num">@c.CaseNumber</span>
                                    </td>
                                    <td class="font-medium text-ink">@c.Title</td>
                                    <td class="hidden md:table-cell text-muted">@c.Client?.FullName</td>
                                    <td><LfStatusChip Status="@c.Status" /></td>
                                    <td class="hidden sm:table-cell font-mono text-xs text-muted">@(c.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd"))</td>
                                    <td class="text-right pr-5">
                                        <LfButton Href="@($"/{_role.ToLower()}/cases/{c.Id}")" Variant="ghost" Size="sm" EndIcon="arrow-up-right">Open</LfButton>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </ChildContent>
    </LfCard>
}

@code {
    private bool _loading = true;
    private string _fullName = string.Empty;
    private string _role = string.Empty;
    private string _userId = string.Empty;

    private AdminStats? _adminStats;
    private JudgeStats? _judgeStats;
    private LawyerStats? _lawyerStats;
    private ClientStats? _clientStats;
    private PoliceStats? _policeStats;
    private ClerkStats? _clerkStats;

    private CaseCompletionTrends? _trends;
    private VerdictDistribution? _verdicts;
    private List<LfDonutChart.Slice> _verdictSlices = new();

    private List<Case> _recentCases = new();

    private string Greeting
    {
        get
        {
            var h = DateTime.Now.Hour;
            if (h < 5)  return "Good evening";
            if (h < 12) return "Good morning";
            if (h < 17) return "Good afternoon";
            return "Good evening";
        }
    }

    private string _subtitle = "Smart Judicial Portal — case lifecycle in one place.";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            if (!(user.Identity?.IsAuthenticated ?? false))
            {
                // Not signed in — let MainLayout's auth check handle the redirect.
                return;
            }

            // Pull identity claims (with sane fallbacks so the greeting never renders blank).
            _fullName = user.FindFirst(ClaimTypes.GivenName)?.Value ?? "";
            if (string.IsNullOrWhiteSpace(_fullName))
                _fullName = user.Identity?.Name ?? "";
            if (string.IsNullOrWhiteSpace(_fullName))
                _fullName = "there";

            _role   = user.FindFirst(ClaimTypes.Role)?.Value ?? "Client";
            _userId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? "";
            var roleLower = _role.ToLowerInvariant();

            _subtitle = _role switch
            {
                "Admin"  => "System-wide oversight across courts, registry, and audit trail.",
                "Judge"  => "Your presiding caseload, hearings, and pending verdicts.",
                "Lawyer" => "Active defense engagements and offered cases.",
                "Client" => "Status of your lodged complaints and filings.",
                "Police" => "Investigation queue and recent report submissions.",
                "Clerk"  => "Hearing scheduling and verdict publication queue.",
                _        => "Smart Judicial Portal — case lifecycle in one place.",
            };

            // Role sub-route correction — purely cosmetic. All these URLs map to this
            // same component class, so Blazor REUSES the existing instance on redirect
            // (OnInitializedAsync does not re-run). That means we must NOT early-return
            // here — we'd strand the component with _loading=true forever. Just fire the
            // navigation and continue loading data inline; the URL update is harmless.
            var route = Navigation.ToBaseRelativePath(Navigation.Uri).Trim('/').ToLowerInvariant();
            var firstSegment = route.Split('/', StringSplitOptions.RemoveEmptyEntries).FirstOrDefault();
            var knownRoles = new[] { "admin", "lawyer", "client", "judge", "police", "clerk" };
            var hasRoleSegment = !string.IsNullOrEmpty(firstSegment) && knownRoles.Contains(firstSegment);
            var mismatch = hasRoleSegment && firstSegment != roleLower;
            var isGenericDashboardRoute = string.IsNullOrEmpty(route) || route == "dashboard";

            if (mismatch || isGenericDashboardRoute)
            {
                Navigation.NavigateTo($"/{roleLower}/dashboard", replace: true);
            }

            // Role-specific stats
            switch (_role)
            {
                case "Admin":  _adminStats  = await DashboardService.GetAdminStatsAsync(); break;
                case "Judge":  _judgeStats  = await DashboardService.GetJudgeStatsAsync(_userId); break;
                case "Lawyer": _lawyerStats = await DashboardService.GetLawyerStatsAsync(_userId); break;
                case "Client": _clientStats = await DashboardService.GetClientStatsAsync(_userId); break;
                case "Police": _policeStats = await DashboardService.GetPoliceStatsAsync(_userId); break;
                case "Clerk":  _clerkStats  = await DashboardService.GetClerkStatsAsync(_userId); break;
            }

            // Charts (admin/judge/lawyer only)
            if (_role is "Admin" or "Judge" or "Lawyer")
            {
                _trends   = await DashboardService.GetCaseCompletionTrendsAsync();
                _verdicts = await DashboardService.GetVerdictDistributionAsync();

                if (_verdicts != null)
                {
                    _verdictSlices = new List<LfDonutChart.Slice>
                    {
                        new("Guilty",    _verdicts.Guilty,    "primary"),
                        new("Acquitted", _verdicts.Acquitted, "info"),
                        new("Dismissed", _verdicts.Dismissed, "success"),
                        new("Appealed",  _verdicts.Appealed,  "warning"),
                    };
                }
            }

            // Recent cases — safe enum parse
            if (Enum.TryParse<UserRole>(_role, ignoreCase: true, out var parsedRole))
            {
                var cases = await CaseService.GetCasesForUserAsync(_userId, parsedRole);
                _recentCases = cases.Take(8).ToList();
            }
        }
        catch (Exception ex)
        {
            // Surface the failure but don't leave the user staring at a skeleton forever.
            Toast.Error($"Dashboard failed to load: {ex.Message}");
        }
        finally
        {
            _loading = false;
        }
    }
}
