@page "/"
@page "/dashboard"
@page "/admin/dashboard"
@page "/lawyer/dashboard"
@page "/client/dashboard"
@page "/judge/dashboard"
@page "/police/dashboard"
@page "/clerk/dashboard"
@attribute [Authorize]
@inject DashboardService DashboardService
@inject CaseService CaseService
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@using System.Security.Claims

<PageTitle>Dashboard - LawFlow</PageTitle>

<div class="lf-page-transition">
    <!-- Top Welcome Banner -->
    <div class="d-flex flex-column flex-sm-row justify-space-between align-start align-sm-center mb-6 pa-6 lf-glass-panel" style="border-radius: 16px;">
        <div>
            <MudText Typo="Typo.h4" Class="font-weight-bold" Style="color: var(--lf-primary); font-weight: 700;">
                Welcome, @_fullName
            </MudText>
            <MudText Typo="Typo.body2" Class="text-muted mt-1">Smart Judicial Portal — LawFlow Enterprise Dashboard</MudText>
        </div>
        <div class="mt-4 mt-sm-0">
            <MudChip T="string" Color="Color.Primary" Variant="Variant.Filled" Size="Size.Large" Icon="@Icons.Material.Filled.Security" Style="border-radius: 8px;">
                Role: @_role
            </MudChip>
        </div>
    </div>

    <!-- ROLE SPECIFIC METRICS & QUICK ACTIONS -->
    @if (_loading)
    {
        <div class="d-flex justify-center align-center py-10">
            <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
        </div>
    }
    else
    {
        <!-- Metrics Grid -->
        <MudGrid Class="mb-6">
            @if (_role == "Admin" && _adminStats != null)
            {
                <MudItem xs="12" sm="4" md="2">
                    <MudPaper Class="pa-4 lf-glow-card" Style="background: linear-gradient(135deg, #1E3A8A 0%, #3B82F6 100%); color: white;">
                        <MudText Typo="Typo.subtitle2" Class="font-weight-bold opacity-75">Total Cases</MudText>
                        <MudText Typo="Typo.h3" Class="font-weight-bold mt-1">@_adminStats.TotalCases</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="4" md="2">
                    <MudPaper Class="pa-4 lf-glow-card" Style="background: white; border-left: 5px solid #EF4444;">
                        <MudText Typo="Typo.subtitle2" Class="text-muted font-weight-bold">Pending Review</MudText>
                        <MudText Typo="Typo.h3" Class="font-weight-bold mt-1 text-danger">@_adminStats.PendingReview</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="4" md="2">
                    <MudPaper Class="pa-4 lf-glow-card" Style="background: white; border-left: 5px solid #F59E0B;">
                        <MudText Typo="Typo.subtitle2" Class="text-muted font-weight-bold">Active Investigations</MudText>
                        <MudText Typo="Typo.h3" Class="font-weight-bold mt-1 text-warning">@_adminStats.ActiveInvestigations</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="4" md="2">
                    <MudPaper Class="pa-4 lf-glow-card" Style="background: white; border-left: 5px solid #3B82F6;">
                        <MudText Typo="Typo.subtitle2" Class="text-muted font-weight-bold">In Hearings</MudText>
                        <MudText Typo="Typo.h3" Class="font-weight-bold mt-1 text-primary">@_adminStats.ActiveHearings</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="4" md="2">
                    <MudPaper Class="pa-4 lf-glow-card" Style="background: white; border-left: 5px solid #10B981;">
                        <MudText Typo="Typo.subtitle2" Class="text-muted font-weight-bold">Closed Cases</MudText>
                        <MudText Typo="Typo.h3" Class="font-weight-bold mt-1 text-success">@_adminStats.ClosedCases</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="4" md="2">
                    <MudPaper Class="pa-4 lf-glow-card" Style="background: white; border-left: 5px solid #8B5CF6;">
                        <MudText Typo="Typo.subtitle2" Class="text-muted font-weight-bold">Active Staff</MudText>
                        <MudText Typo="Typo.h3" Class="font-weight-bold mt-1 text-purple">@_adminStats.ActiveUsers</MudText>
                    </MudPaper>
                </MudItem>
            }
            else if (_role == "Judge" && _judgeStats != null)
            {
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Class="pa-4 lf-glow-card" Style="background: linear-gradient(135deg, #1E3A8A 0%, #3B82F6 100%); color: white;">
                        <MudText Typo="Typo.subtitle2" Class="font-weight-bold opacity-75">Assigned Cases</MudText>
                        <MudText Typo="Typo.h3" Class="font-weight-bold mt-1">@_judgeStats.TotalAssigned</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Class="pa-4 lf-glow-card" Style="background: white; border-left: 5px solid #EF4444;">
                        <MudText Typo="Typo.subtitle2" Class="text-muted font-weight-bold">Verdict Pending</MudText>
                        <MudText Typo="Typo.h3" Class="font-weight-bold mt-1 text-danger">@_judgeStats.VerdictPending</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Class="pa-4 lf-glow-card" Style="background: white; border-left: 5px solid #F59E0B;">
                        <MudText Typo="Typo.subtitle2" Class="text-muted font-weight-bold">Scheduled Hearings</MudText>
                        <MudText Typo="Typo.h3" Class="font-weight-bold mt-1 text-warning">@_judgeStats.ScheduledHearings</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Class="pa-4 lf-glow-card" Style="background: white; border-left: 5px solid #10B981;">
                        <MudText Typo="Typo.subtitle2" Class="text-muted font-weight-bold">Closed Presided Cases</MudText>
                        <MudText Typo="Typo.h3" Class="font-weight-bold mt-1 text-success">@_judgeStats.ClosedCases</MudText>
                    </MudPaper>
                </MudItem>
            }
            else if (_role == "Lawyer" && _lawyerStats != null)
            {
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Class="pa-4 lf-glow-card" Style="background: linear-gradient(135deg, #0EA5E9 0%, #1E3A8A 100%); color: white;">
                        <MudText Typo="Typo.subtitle2" Class="font-weight-bold opacity-75">Active Clients</MudText>
                        <MudText Typo="Typo.h3" Class="font-weight-bold mt-1">@_lawyerStats.ActiveCases</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Class="pa-4 lf-glow-card" Style="background: white; border-left: 5px solid #10B981;">
                        <MudText Typo="Typo.subtitle2" Class="text-muted font-weight-bold">Resolved Cases</MudText>
                        <MudText Typo="Typo.h3" Class="font-weight-bold mt-1 text-success">@_lawyerStats.CompletedCases</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Class="pa-4 lf-glow-card" Style="background: white; border-left: 5px solid #3B82F6;">
                        <MudText Typo="Typo.subtitle2" Class="text-muted font-weight-bold">Upcoming Court Hearings</MudText>
                        <MudText Typo="Typo.h3" Class="font-weight-bold mt-1 text-primary">@_lawyerStats.UpcomingHearings</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="6" md="3">
                    <MudPaper Class="pa-4 lf-glow-card lf-pulse-badge" Style="background: white; border-left: 5px solid #EF4444;">
                        <MudText Typo="Typo.subtitle2" Class="text-muted font-weight-bold">Cases Offered</MudText>
                        <MudText Typo="Typo.h3" Class="font-weight-bold mt-1 text-danger">@_lawyerStats.OfferedCases</MudText>
                    </MudPaper>
                </MudItem>
            }
            else if (_role == "Client" && _clientStats != null)
            {
                <MudItem xs="12" sm="4">
                    <MudPaper Class="pa-4 lf-glow-card" Style="background: linear-gradient(135deg, #1E3A8A 0%, #3B82F6 100%); color: white;">
                        <MudText Typo="Typo.subtitle2" Class="font-weight-bold opacity-75">My Lodged Cases</MudText>
                        <MudText Typo="Typo.h3" Class="font-weight-bold mt-1">@_clientStats.TotalCases</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudPaper Class="pa-4 lf-glow-card" Style="background: white; border-left: 5px solid #F59E0B;">
                        <MudText Typo="Typo.subtitle2" Class="text-muted font-weight-bold">Active Cases</MudText>
                        <MudText Typo="Typo.h3" Class="font-weight-bold mt-1 text-warning">@_clientStats.ActiveCases</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudPaper Class="pa-4 lf-glow-card" Style="background: white; border-left: 5px solid #10B981;">
                        <MudText Typo="Typo.subtitle2" Class="text-muted font-weight-bold">Closed Cases</MudText>
                        <MudText Typo="Typo.h3" Class="font-weight-bold mt-1 text-success">@_clientStats.ClosedCases</MudText>
                    </MudPaper>
                </MudItem>
            }
            else if (_role == "Police" && _policeStats != null)
            {
                <MudItem xs="12" sm="4">
                    <MudPaper Class="pa-4 lf-glow-card" Style="background: linear-gradient(135deg, #1E3A8A 0%, #0EA5E9 100%); color: white;">
                        <MudText Typo="Typo.subtitle2" Class="font-weight-bold opacity-75">Investigation Queue</MudText>
                        <MudText Typo="Typo.h3" Class="font-weight-bold mt-1">@_policeStats.TotalAssigned</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudPaper Class="pa-4 lf-glow-card" Style="background: white; border-left: 5px solid #F59E0B;">
                        <MudText Typo="Typo.subtitle2" Class="text-muted font-weight-bold">Active Cases</MudText>
                        <MudText Typo="Typo.h3" Class="font-weight-bold mt-1 text-warning">@_policeStats.UnderInvestigation</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudPaper Class="pa-4 lf-glow-card" Style="background: white; border-left: 5px solid #10B981;">
                        <MudText Typo="Typo.subtitle2" Class="text-muted font-weight-bold">Reports Filed</MudText>
                        <MudText Typo="Typo.h3" Class="font-weight-bold mt-1 text-success">@_policeStats.ReportsSubmitted</MudText>
                    </MudPaper>
                </MudItem>
            }
            else if (_role == "Clerk" && _clerkStats != null)
            {
                <MudItem xs="12" sm="4">
                    <MudPaper Class="pa-4 lf-glow-card" Style="background: linear-gradient(135deg, #1E3A8A 0%, #3B82F6 100%); color: white;">
                        <MudText Typo="Typo.subtitle2" Class="font-weight-bold opacity-75">Assigned Cases</MudText>
                        <MudText Typo="Typo.h3" Class="font-weight-bold mt-1">@_clerkStats.TotalAssigned</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudPaper Class="pa-4 lf-glow-card" Style="background: white; border-left: 5px solid #3B82F6;">
                        <MudText Typo="Typo.subtitle2" Class="text-muted font-weight-bold">Scheduled Hearings</MudText>
                        <MudText Typo="Typo.h3" Class="font-weight-bold mt-1 text-primary">@_clerkStats.ScheduledHearings</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudPaper Class="pa-4 lf-glow-card" Style="background: white; border-left: 5px solid #F59E0B;">
                        <MudText Typo="Typo.subtitle2" Class="text-muted font-weight-bold">Verdicts Pending Publication</MudText>
                        <MudText Typo="Typo.h3" Class="font-weight-bold mt-1 text-warning">@_clerkStats.PendingVerdicts</MudText>
                    </MudPaper>
                </MudItem>
            }
        </MudGrid>

        <!-- Quick Actions Panel -->
        <div class="lf-glass-panel pa-6 mb-6">
            <MudText Typo="Typo.h6" Class="font-weight-bold mb-4">
                <MudIcon Icon="@Icons.Material.Filled.Bolt" Color="Color.Warning" Class="mr-2" />
                Quick Actions
            </MudText>
            <div class="d-flex flex-wrap gap-4">
                @if (_role == "Client")
                {
                    <MudButton Href="/cases" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" Style="border-radius: 8px;">
                        Submit New Case (FIR)
                    </MudButton>
                }
                <MudButton Href="/cases" Variant="Variant.Filled" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.FolderOpen" Style="border-radius: 8px;">
                    View Case Records
                </MudButton>
                @if (_role == "Clerk" || _role == "Admin")
                {
                    <MudButton Href="/hearings" Variant="Variant.Filled" Color="Color.Success" StartIcon="@Icons.Material.Filled.Add" Style="border-radius: 8px;">
                        Schedule Judicial Hearing
                    </MudButton>
                }
                @if (_role == "Admin")
                {
                    <MudButton Href="/admin/users" Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.PersonAdd" Style="border-radius: 8px;">
                        Manage Judicial Accounts
                    </MudButton>
                    <MudButton Href="/admin/logs" Variant="Variant.Filled" Color="Color.Dark" StartIcon="@Icons.Material.Filled.History" Style="border-radius: 8px;">
                        System Activity Logs
                    </MudButton>
                }
            </div>
        </div>

        <!-- CHARTS SECTION (Admins & Judges & Lawyers) -->
        @if (_role == "Admin" || _role == "Judge" || _role == "Lawyer")
        {
            <MudGrid Class="mb-6">
                <!-- Case Trend Line Chart -->
                <MudItem xs="12" md="8">
                    <MudPaper Class="pa-6 lf-glass-panel" Style="height: 400px; border-radius: 16px;">
                        <div class="d-flex justify-space-between align-center mb-4">
                            <MudText Typo="Typo.h6" Class="font-weight-bold">Monthly Judicial Case Analytics</MudText>
                            <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small">Year @DateTime.UtcNow.Year</MudChip>
                        </div>
                        @if (_trends != null)
                        {
                            <MudChart T="double" ChartType="ChartType.Line" 
                                      ChartSeries="@_series" 
                                      XAxisLabels="@_trends.Months" 
                                      Width="100%" 
                                      Height="300px" 
                                      ChartOptions="@_chartOptions" />
                        }
                    </MudPaper>
                </MudItem>

                <!-- Verdict Distribution Donut Chart -->
                <MudItem xs="12" md="4">
                    <MudPaper Class="pa-6 lf-glass-panel" Style="height: 400px; border-radius: 16px;">
                        <MudText Typo="Typo.h6" Class="font-weight-bold mb-4">Verdict Distribution</MudText>
                        @if (_verdicts != null)
                        {
                            <MudChart T="double" ChartType="ChartType.Donut" 
                                      InputData="@_donutData" 
                                      InputLabels="@_donutLabels" 
                                      Width="100%" 
                                      Height="250px" />
                            <div class="d-flex justify-space-around mt-4" style="font-size: 11px;">
                                <div><span style="color:#1E3A8A; font-weight:700;">●</span> Guilty (@_verdicts.Guilty)</div>
                                <div><span style="color:#0EA5E9; font-weight:700;">●</span> Acquitted (@_verdicts.Acquitted)</div>
                                <div><span style="color:#10B981; font-weight:700;">●</span> Dismissed (@_verdicts.Dismissed)</div>
                                <div><span style="color:#F59E0B; font-weight:700;">●</span> Appealed (@_verdicts.Appealed)</div>
                            </div>
                        }
                    </MudPaper>
                </MudItem>
            </MudGrid>
        }

        <!-- RECENT CASES LIST -->
        <MudPaper Class="pa-6 lf-glass-panel" Style="border-radius: 16px;">
            <div class="d-flex justify-space-between align-center mb-4">
                <MudText Typo="Typo.h6" Class="font-weight-bold">Recent Case Activities</MudText>
                <MudButton Href="/cases" EndIcon="@Icons.Material.Filled.ArrowForward" Color="Color.Primary" Size="Size.Small">View All</MudButton>
            </div>

            <MudTable Items="@_recentCases" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="0" Style="background: transparent;">
                <HeaderContent>
                    <MudTh>Case Number</MudTh>
                    <MudTh>Title</MudTh>
                    <MudTh>Client</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh>Filing Date</MudTh>
                    <MudTh Style="text-align: right;">Action</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Case Number">
                        <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small" Style="border-radius:6px; font-weight:600;">
                            @context.CaseNumber
                        </MudChip>
                    </MudTd>
                    <MudTd DataLabel="Title" Style="font-weight: 500;">@context.Title</MudTd>
                    <MudTd DataLabel="Client">@context.Client?.FullName</MudTd>
                    <MudTd DataLabel="Status">
                        <MudChip T="string" Color="@GetStatusColor(context.Status)" Size="Size.Small" Style="border-radius:6px; font-weight: 600;">
                            @GetStatusLabel(context.Status)
                        </MudChip>
                    </MudTd>
                    <MudTd DataLabel="Filing Date">@context.CreatedAt.ToLocalTime().ToString("d")</MudTd>
                    <MudTd Style="text-align: right;">
                        <MudButton Href="@($"/{_role.ToLower()}/cases/{context.Id}")" Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" Style="border-radius: 6px; text-transform:none;">
                            Open Portal
                        </MudButton>
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager PageSizeOptions="new int[]{5, 10}" />
                </PagerContent>
            </MudTable>
        </MudPaper>
    }
</div>

@code {
    private bool _loading = true;
    private string _fullName = string.Empty;
    private string _role = string.Empty;
    private string _userId = string.Empty;

    // Aggregates
    private AdminStats? _adminStats;
    private JudgeStats? _judgeStats;
    private LawyerStats? _lawyerStats;
    private ClientStats? _clientStats;
    private PoliceStats? _policeStats;
    private ClerkStats? _clerkStats;

    // Charts
    private CaseCompletionTrends? _trends;
    private VerdictDistribution? _verdicts;
    private List<ChartSeries<double>> _series = new();
    private double[] _donutData = Array.Empty<double>();
    private string[] _donutLabels = new[] { "Guilty", "Acquitted", "Dismissed", "Appealed" };
    private ChartOptions _chartOptions = new();

    private List<Case> _recentCases = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated ?? false)
        {
            _fullName = user.FindFirst(ClaimTypes.GivenName)?.Value ?? user.Identity.Name ?? "User";
            _role = user.FindFirst(ClaimTypes.Role)?.Value ?? "Client";
            _userId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? "";

            // Role sub-routing correction
            var currentUri = Navigation.Uri.ToLower();
            bool mismatch = false;
            if (currentUri.Contains("/admin/") && _role != "Admin") mismatch = true;
            if (currentUri.Contains("/lawyer/") && _role != "Lawyer") mismatch = true;
            if (currentUri.Contains("/client/") && _role != "Client") mismatch = true;
            if (currentUri.Contains("/judge/") && _role != "Judge") mismatch = true;
            if (currentUri.Contains("/police/") && _role != "Police") mismatch = true;
            if (currentUri.Contains("/clerk/") && _role != "Clerk") mismatch = true;

            if (mismatch || currentUri.EndsWith("/dashboard") || currentUri.EndsWith("/dashboard/") || currentUri.EndsWith("/") || currentUri.EndsWith("/#/"))
            {
                var correctRole = _role.ToLower();
                Navigation.NavigateTo($"/{correctRole}/dashboard");
                return;
            }

            // Load metrics based on Role
            switch (_role)
            {
                case "Admin":
                    _adminStats = await DashboardService.GetAdminStatsAsync();
                    break;
                case "Judge":
                    _judgeStats = await DashboardService.GetJudgeStatsAsync(_userId);
                    break;
                case "Lawyer":
                    _lawyerStats = await DashboardService.GetLawyerStatsAsync(_userId);
                    break;
                case "Client":
                    _clientStats = await DashboardService.GetClientStatsAsync(_userId);
                    break;
                case "Police":
                    _policeStats = await DashboardService.GetPoliceStatsAsync(_userId);
                    break;
                case "Clerk":
                    _clerkStats = await DashboardService.GetClerkStatsAsync(_userId);
                    break;
            }

            // Load charts data (common for Admins/Judges/Lawyers)
            if (_role == "Admin" || _role == "Judge" || _role == "Lawyer")
            {
                _trends = await DashboardService.GetCaseCompletionTrendsAsync();
                _verdicts = await DashboardService.GetVerdictDistributionAsync();

                _series = new List<ChartSeries<double>>
                {
                    new ChartSeries<double> { Name = "Cases Filed", Data = _trends.CasesFiled },
                    new ChartSeries<double> { Name = "Cases Closed", Data = _trends.CasesClosed }
                };

                _donutData = new double[] { _verdicts.Guilty, _verdicts.Acquitted, _verdicts.Dismissed, _verdicts.Appealed };
            }

            // Load recent cases for quick overview
            var cases = await CaseService.GetCasesForUserAsync(_userId, Enum.Parse<UserRole>(_role));
            _recentCases = cases.Take(5).ToList();
        }

        _loading = false;
    }

    private Color GetStatusColor(CaseStatus status)
    {
        return status switch
        {
            CaseStatus.Created => Color.Default,
            CaseStatus.ReviewedByAdmin => Color.Primary,
            CaseStatus.AssignedToJudgeAndPolice => Color.Info,
            CaseStatus.AvailableForLawyers => Color.Warning,
            CaseStatus.LawyerAccepted => Color.Warning,
            CaseStatus.AssignedToLawyer => Color.Info,
            CaseStatus.ClerkAssignedByJudge => Color.Info,
            CaseStatus.Investigation => Color.Warning,
            CaseStatus.Hearing => Color.Primary,
            CaseStatus.VerdictIssued => Color.Secondary,
            CaseStatus.Closed => Color.Success,
            _ => Color.Default
        };
    }

    private string GetStatusLabel(CaseStatus status)
    {
        return status switch
        {
            CaseStatus.Created => "Complaint Lodged",
            CaseStatus.ReviewedByAdmin => "Reviewed By Admin",
            CaseStatus.AssignedToJudgeAndPolice => "Officials Appointed",
            CaseStatus.AvailableForLawyers => "Open for Defense",
            CaseStatus.LawyerAccepted => "Lawyer Accepting",
            CaseStatus.AssignedToLawyer => "Defense Retained",
            CaseStatus.ClerkAssignedByJudge => "Clerk Assigned",
            CaseStatus.Investigation => "Under Investigation",
            CaseStatus.Hearing => "Court Hearings",
            CaseStatus.VerdictIssued => "Verdict Issued",
            CaseStatus.Closed => "Closed / Archived",
            _ => "Unknown"
        };
    }
}
