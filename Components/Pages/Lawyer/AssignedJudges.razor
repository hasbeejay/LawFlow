@page "/lawyer/judges"
@attribute [Authorize(Roles = "Lawyer")]
@inject CaseService CaseService
@inject AuthService AuthService
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Assigned Judges — LawFlow</PageTitle>

<div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-6">
    <div>
        <div class="font-mono text-2xs uppercase tracking-[0.18em] text-muted flex items-center gap-2">
            <span class="w-6 h-px bg-muted/60"></span>
            <span>Lawyer · Judges</span>
        </div>
        <h1 class="mt-1.5 text-2xl md:text-3xl font-semibold tracking-tight text-balance">Judges on your active cases</h1>
        <p class="mt-1 text-sm text-muted">Presiding judges across cases you currently represent.</p>
    </div>
</div>

@if (_loading)
{
    <div class="lf-card p-10 text-center text-sm text-muted">Loading…</div>
}
else if (_rows.Count == 0)
{
    <div class="lf-card p-10 text-center text-sm text-muted">No judges yet — your cases haven't reached assignment.</div>
}
else
{
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        @foreach (var (judge, cases) in _rows)
        {
            <div class="lf-card p-5">
                <div class="flex items-center gap-3">
                    <LfAvatar Name="@judge.FullName" Size="lg" />
                    <div class="min-w-0">
                        <div class="text-sm font-semibold text-ink truncate">@judge.FullName</div>
                        <div class="font-mono text-2xs text-muted">@(judge.Specialization ?? "Presiding Judge")</div>
                    </div>
                </div>
                <div class="mt-3 font-mono text-2xs uppercase tracking-wider text-muted">Cases · @cases.Count</div>
                <ul class="mt-1 space-y-1 text-sm">
                    @foreach (var c in cases.Take(4))
                    {
                        <li class="flex items-center justify-between gap-2">
                            <span class="lf-tag-num">@c.CaseNumber</span>
                            <span class="truncate text-muted">@c.Title</span>
                        </li>
                    }
                </ul>
            </div>
        }
    </div>
}

@code {
    private bool _loading = true;
    private string _userId = "";
    private List<(ApplicationUser Judge, List<Case> Cases)> _rows = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var auth = await AuthStateProvider.GetAuthenticationStateAsync();
            _userId = auth.User.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? "";

            var cases = await CaseService.GetCasesForUserAsync(_userId, UserRole.Lawyer);
            _rows = cases
                .Where(c => !string.IsNullOrEmpty(c.JudgeId) && c.Judge != null)
                .GroupBy(c => c.JudgeId!)
                .Select(g => (g.First().Judge!, g.ToList()))
                .ToList();
        }
        finally { _loading = false; }
    }
}
