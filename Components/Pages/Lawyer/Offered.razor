@page "/lawyer/offered"
@attribute [Authorize(Roles = "Lawyer")]
@inject CaseService CaseService
@inject AuthenticationStateProvider AuthStateProvider
@inject ToastService Toast

<PageTitle>Offered Cases — LawFlow</PageTitle>

<div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-6">
    <div>
        <div class="font-mono text-2xs uppercase tracking-[0.18em] text-muted flex items-center gap-2">
            <span class="w-6 h-px bg-muted/60"></span>
            <span>Lawyer</span>
        </div>
        <h1 class="mt-1.5 text-2xl md:text-3xl font-semibold tracking-tight text-balance">Offered cases</h1>
        <p class="mt-1 text-sm text-muted">Cases forwarded to you or open to any lawyer. Accept to take the brief.</p>
    </div>
</div>

@if (_loading)
{
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
        @for (int i = 0; i < 4; i++)
        {
            <div class="lf-card p-5 animate-pulse">
                <div class="h-3 w-24 bg-hairline rounded-xs"></div>
                <div class="mt-3 h-5 w-3/4 bg-hairline rounded-xs"></div>
                <div class="mt-3 h-3 w-full bg-hairline/60 rounded-xs"></div>
            </div>
        }
    </div>
}
else if (_offers.Count == 0)
{
    <div class="lf-card p-10 text-center">
        <div class="inline-flex items-center justify-center w-12 h-12 rounded-card bg-canvas border border-hairline text-muted">
            <LfIcon Name="inbox" Size="20" />
        </div>
        <div class="mt-3 text-sm text-muted">No offered cases right now.</div>
    </div>
}
else
{
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
        @foreach (var c in _offers)
        {
            <div class="lf-card p-5">
                <div class="flex items-start justify-between gap-3">
                    <span class="lf-tag-num">@c.CaseNumber</span>
                    @if (c.LawyerId == _userId)
                    {
                        <LfChip Tone="primary" ShowDot="true">Direct offer to you</LfChip>
                    }
                    else
                    {
                        <LfChip Tone="neutral" ShowDot="false">Open to any lawyer</LfChip>
                    }
                </div>
                <div class="mt-3 font-semibold text-ink">@c.Title</div>
                <div class="mt-1 text-xs text-muted line-clamp-3">@c.Description</div>
                <div class="mt-3 flex items-center justify-between text-2xs font-mono text-muted">
                    <span>Client · @c.Client?.FullName</span>
                    <span>Filed · @c.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd")</span>
                </div>
                <div class="mt-4 flex items-center gap-2">
                    <LfButton OnClick="@(() => Accept(c.Id))" Variant="primary" Icon="check">Accept</LfButton>
                    <LfButton OnClick="@(() => Decline(c.Id))" Variant="outline" Icon="x">Decline</LfButton>
                    <LfButton Href="@($"/lawyer/cases/{c.Id}")" Variant="ghost" EndIcon="arrow-up-right">View</LfButton>
                </div>
            </div>
        }
    </div>
}

@code {
    private bool _loading = true;
    private string _userId = "";
    private List<Case> _offers = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var auth = await AuthStateProvider.GetAuthenticationStateAsync();
            _userId = auth.User.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? "";
            await Reload();
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task Reload()
    {
        var all = await CaseService.GetCasesForUserAsync(_userId, UserRole.Lawyer);
        _offers = all
            .Where(c => c.Status == CaseStatus.AvailableForLawyers
                     && (string.IsNullOrEmpty(c.LawyerId) || c.LawyerId == _userId))
            .ToList();
    }

    private async Task Accept(int caseId)
    {
        var ok = await CaseService.UpdateLawyerAssignmentAsync(caseId, _userId, true);
        if (ok) Toast.Success("Case accepted."); else Toast.Error("Could not accept this case.");
        await Reload();
    }

    private async Task Decline(int caseId)
    {
        var ok = await CaseService.UpdateLawyerAssignmentAsync(caseId, _userId, false);
        if (ok) Toast.Info("Case declined."); else Toast.Error("Could not decline.");
        await Reload();
    }
}
