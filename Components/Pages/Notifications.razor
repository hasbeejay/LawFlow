@page "/notifications"
@attribute [Authorize(Roles = "Admin,Judge,Lawyer,Client,Police,Clerk")]
@inject NotificationService NotificationService
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Notifications — LawFlow</PageTitle>

<div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-6">
    <div>
        <div class="font-mono text-2xs uppercase tracking-[0.18em] text-muted flex items-center gap-2">
            <span class="w-6 h-px bg-muted/60"></span>
            <span>Notifications</span>
        </div>
        <h1 class="mt-1.5 text-2xl md:text-3xl font-semibold tracking-tight text-balance">Your inbox</h1>
        <p class="mt-1 text-sm text-muted">@_unread unread · @_items.Count total (last 50)</p>
    </div>
    @if (_unread > 0)
    {
        <LfButton OnClick="MarkAllRead" Variant="outline" Icon="check-check">Mark all read</LfButton>
    }
</div>

@if (_loading)
{
    <div class="space-y-2">
        @for (int i = 0; i < 5; i++)
        {
            <div class="lf-card p-4 animate-pulse">
                <div class="h-3 w-1/3 bg-hairline rounded-xs"></div>
                <div class="mt-2 h-4 w-2/3 bg-hairline rounded-xs"></div>
            </div>
        }
    </div>
}
else if (_items.Count == 0)
{
    <div class="lf-card p-10 text-center">
        <div class="inline-flex items-center justify-center w-12 h-12 rounded-card bg-canvas border border-hairline text-muted">
            <LfIcon Name="bell" Size="20" />
        </div>
        <div class="mt-3 text-sm text-muted">You're all caught up.</div>
    </div>
}
else
{
    <div class="space-y-2">
        @foreach (var n in _items)
        {
            <button type="button" @onclick="@(() => MarkRead(n))"
                    class="w-full text-left lf-card p-4 hover:border-primary/40 transition-colors flex items-start gap-3">
                <span class="mt-1.5 w-2 h-2 rounded-full @(n.IsRead ? "bg-hairline" : "bg-primary") shrink-0"></span>
                <div class="flex-1 min-w-0">
                    <div class="flex items-center justify-between gap-3">
                        <div class="text-sm font-semibold text-ink truncate">@n.Title</div>
                        <div class="font-mono text-2xs text-muted">@n.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</div>
                    </div>
                    <div class="mt-1 text-sm text-muted">@n.Message</div>
                </div>
            </button>
        }
    </div>
}

@code {
    private bool _loading = true;
    private string _userId = "";
    private List<Notification> _items = new();
    private int _unread = 0;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var auth = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = auth.User;
            if (!(user.Identity?.IsAuthenticated ?? false)) return;
            _userId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? "";
            await Reload();
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task Reload()
    {
        _items = await NotificationService.GetNotificationsForUserAsync(_userId);
        _unread = await NotificationService.GetUnreadCountAsync(_userId);
    }

    private async Task MarkRead(Notification n)
    {
        if (n.IsRead) return;
        await NotificationService.MarkAsReadAsync(n.Id);
        n.IsRead = true;
        _unread = Math.Max(0, _unread - 1);
    }

    private async Task MarkAllRead()
    {
        await NotificationService.MarkAllAsReadAsync(_userId);
        foreach (var n in _items) n.IsRead = true;
        _unread = 0;
    }
}
