@page "/clerk/verdicts"
@attribute [Authorize(Roles = "Clerk,Admin")]
@inject CaseService CaseService
@inject VerdictService VerdictService
@inject AuthenticationStateProvider AuthStateProvider
@inject ISnackbar Snackbar
@using System.Security.Claims
@using LawFlow.Models

<PageTitle>Verdict Registry - LawFlow</PageTitle>

<div class="lf-page-transition">
    <div class="d-flex flex-column flex-sm-row justify-space-between align-start align-sm-center mb-6">
        <div>
            <MudText Typo="Typo.h4" Class="font-weight-bold" Style="color: var(--lf-primary); font-weight: 700;">
                Judgement Verdict Registry
            </MudText>
            <MudText Typo="Typo.body2" Class="text-muted mt-1">Review issued judge verdicts, officially publish decrees, and conclude active filings.</MudText>
        </div>
    </div>

    @if (_loading)
    {
        <div class="d-flex justify-center py-10">
            <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
        </div>
    }
    else
    {
        <MudGrid>
            <!-- Verdict Analytics -->
            <MudItem xs="12" sm="6">
                <MudPaper Class="pa-4 lf-glow-card lf-pulse-badge" Style="background: white; border-left: 5px solid #F59E0B;">
                    <MudText Typo="Typo.subtitle2" Class="text-muted font-weight-bold">Awaiting Publication / Closed Release</MudText>
                    <MudText Typo="Typo.h3" Class="font-weight-bold mt-1 text-warning">@_cases.Count(c => c.Status == CaseStatus.VerdictIssued)</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudPaper Class="pa-4 lf-glow-card" Style="background: white; border-left: 5px solid #10B981;">
                    <MudText Typo="Typo.subtitle2" Class="text-muted font-weight-bold">Concluded Case Files</MudText>
                    <MudText Typo="Typo.h3" Class="font-weight-bold mt-1 text-success">@_cases.Count(c => c.Status == CaseStatus.Closed)</MudText>
                </MudPaper>
            </MudItem>

            <!-- Case Records Table -->
            <MudItem xs="12">
                <MudPaper Class="pa-6 lf-glass-panel" Style="border-radius: 16px;">
                    <div class="d-flex justify-space-between align-center mb-4">
                        <MudText Typo="Typo.h6" Class="font-weight-bold">Docket Verdict Publications</MudText>
                        <MudTextField @bind-Value="_searchQuery" 
                                      Label="Search by Case Number..." 
                                      Variant="Variant.Outlined" 
                                      Adornment="Adornment.Start" 
                                      AdornmentIcon="@Icons.Material.Filled.Search"
                                      Immediate="true"
                                      OnKeyUp="FilterCases"
                                      Margin="Margin.Dense"
                                      Style="max-width: 300px; background: white;" />
                    </div>

                    <MudTable Items="@_filteredCases" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="0" Style="background:transparent;">
                        <HeaderContent>
                            <MudTh>Case Number</MudTh>
                            <MudTh>Case Title</MudTh>
                            <MudTh>Presiding Judge</MudTh>
                            <MudTh>Status</MudTh>
                            <MudTh>Last Updated</MudTh>
                            <MudTh Style="text-align: right;">Action</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Case Number">
                                <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small" Style="font-weight:600; border-radius:6px;">
                                    @context.CaseNumber
                                </MudChip>
                            </MudTd>
                            <MudTd DataLabel="Case Title" Style="font-weight:600;">@context.Title</MudTd>
                            <MudTd DataLabel="Presiding Judge">@context.Judge?.FullName</MudTd>
                            <MudTd DataLabel="Status">
                                <MudChip T="string" Color="@GetStatusColor(context.Status)" Size="Size.Small" Style="font-weight:600; border-radius:6px;">
                                    @GetStatusLabel(context.Status)
                                </MudChip>
                            </MudTd>
                            <MudTd DataLabel="Last Updated">@(context.UpdatedAt?.ToLocalTime().ToString("g") ?? "N/A")</MudTd>
                            <MudTd Style="text-align: right;">
                                <div class="d-flex justify-end gap-2">
                                    @if (context.Status == CaseStatus.VerdictIssued)
                                    {
                                        <MudButton Variant="Variant.Filled" Color="Color.Success" Size="Size.Small" OnClick="() => HandlePublishVerdict(context.Id)" Style="border-radius:6px; text-transform:none;">
                                            Publish Decree
                                        </MudButton>
                                    }
                                    <MudButton Href="@($"/clerk/cases/{context.Id}")" Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" Style="border-radius:6px; text-transform:none;">
                                        Open Proceedings
                                    </MudButton>
                                </div>
                            </MudTd>
                        </RowTemplate>
                        <PagerContent>
                            <MudTablePager PageSizeOptions="new int[]{10, 25, 50}" />
                        </PagerContent>
                    </MudTable>
                </MudPaper>
            </MudItem>
        </MudGrid>
    }
</div>

@code {
    private bool _loading = true;
    private string _userId = string.Empty;
    private string _searchQuery = string.Empty;
    private List<Case> _cases = new();
    private List<Case> _filteredCases = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _userId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? "";
        await LoadCases();
    }

    private async Task LoadCases()
    {
        _loading = true;
        _cases = await CaseService.GetCasesForUserAsync(_userId, UserRole.Clerk);
        FilterCases();
        _loading = false;
    }

    private void FilterCases()
    {
        if (string.IsNullOrEmpty(_searchQuery))
        {
            _filteredCases = _cases;
        }
        else
        {
            var txt = _searchQuery.ToLower();
            _filteredCases = _cases.Where(c => 
                c.CaseNumber.ToLower().Contains(txt) || 
                c.Title.ToLower().Contains(txt)
            ).ToList();
        }
    }

    private async Task HandlePublishVerdict(int caseId)
    {
        var res = await VerdictService.PublishVerdictAsync(caseId, _userId);
        if (res)
        {
            Snackbar.Add("Verdict published officially. Case is now marked resolved and closed.", Severity.Success);
            await LoadCases();
        }
        else
        {
            Snackbar.Add("Could not publish verdict.", Severity.Error);
        }
    }

    private Color GetStatusColor(CaseStatus status)
    {
        return status switch
        {
            CaseStatus.Created => Color.Default,
            CaseStatus.ReviewedByAdmin => Color.Primary,
            CaseStatus.AssignedToJudgeAndPolice => Color.Info,
            CaseStatus.AvailableForLawyers => Color.Warning,
            CaseStatus.LawyerAccepted => Color.Warning,
            CaseStatus.AssignedToLawyer => Color.Info,
            CaseStatus.ClerkAssignedByJudge => Color.Info,
            CaseStatus.Investigation => Color.Warning,
            CaseStatus.Hearing => Color.Primary,
            CaseStatus.VerdictIssued => Color.Secondary,
            CaseStatus.Closed => Color.Success,
            _ => Color.Default
        };
    }

    private string GetStatusLabel(CaseStatus status)
    {
        return status switch
        {
            CaseStatus.Created => "Complaint Lodged",
            CaseStatus.ReviewedByAdmin => "Reviewed By Admin",
            CaseStatus.AssignedToJudgeAndPolice => "Officials Appointed",
            CaseStatus.AvailableForLawyers => "Open for Defense",
            CaseStatus.LawyerAccepted => "Lawyer Accepting",
            CaseStatus.AssignedToLawyer => "Defense Retained",
            CaseStatus.ClerkAssignedByJudge => "Clerk Assigned",
            CaseStatus.Investigation => "Under Investigation",
            CaseStatus.Hearing => "Court Hearings",
            CaseStatus.VerdictIssued => "Verdict Issued",
            CaseStatus.Closed => "Closed / Archived",
            _ => "Unknown"
        };
    }
}
