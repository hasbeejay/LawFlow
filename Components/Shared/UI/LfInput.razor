@{
    var hasError = !string.IsNullOrEmpty(Error);
    var borderCls = hasError ? "border-danger/70" : "";
    var inputCls = $"lf-input pr-3 {(StartIcon != null ? "pl-9" : "")} {(EndIcon != null || OnEndIconClick.HasDelegate ? "pr-9" : "")} {borderCls}".Trim();
    var rowId = Id ?? $"in-{Guid.NewGuid().ToString("N").Substring(0, 6)}";
}

<div class="flex flex-col gap-1.5 @(Class ?? "")">
    @if (!string.IsNullOrEmpty(Label))
    {
        <label for="@rowId" class="text-xs font-medium text-muted tracking-wide">
            @Label
            @if (Required) { <span class="text-danger">*</span> }
        </label>
    }

    <div class="relative">
        @if (!string.IsNullOrEmpty(StartIcon))
        {
            <span class="absolute left-3 top-1/2 -translate-y-1/2 text-muted">
                <LfIcon Name="@StartIcon" Size="16" />
            </span>
        }

        <input id="@rowId"
               type="@Type"
               value="@Value"
               placeholder="@Placeholder"
               autocomplete="@AutoComplete"
               disabled="@Disabled"
               class="@inputCls"
               @oninput="HandleInput"
               @attributes="ExtraAttrs" />

        @if (OnEndIconClick.HasDelegate && !string.IsNullOrEmpty(EndIcon))
        {
            <button type="button" tabindex="-1" @onclick="OnEndIconClick"
                    class="absolute right-2.5 top-1/2 -translate-y-1/2 text-muted hover:text-ink p-1 rounded-xs">
                <LfIcon Name="@EndIcon" Size="16" />
            </button>
        }
        else if (!string.IsNullOrEmpty(EndIcon))
        {
            <span class="absolute right-3 top-1/2 -translate-y-1/2 text-muted">
                <LfIcon Name="@EndIcon" Size="16" />
            </span>
        }
    </div>

    @if (hasError)
    {
        <div class="flex items-center gap-1.5 text-xs text-danger">
            <LfIcon Name="alert-circle" Size="13" />
            <span class="font-mono text-2xs uppercase tracking-wider">ERR</span>
            <span>@Error</span>
        </div>
    }
    else if (!string.IsNullOrEmpty(Hint))
    {
        <div class="text-xs text-muted">@Hint</div>
    }
</div>

@code {
    [Parameter] public string? Label { get; set; }
    [Parameter] public string? Hint { get; set; }
    [Parameter] public string? Error { get; set; }
    [Parameter] public string Type { get; set; } = "text";
    [Parameter] public string? Placeholder { get; set; }
    [Parameter] public string? StartIcon { get; set; }
    [Parameter] public string? EndIcon { get; set; }
    [Parameter] public string? Value { get; set; }
    [Parameter] public bool Required { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public string? AutoComplete { get; set; }
    [Parameter] public string? Id { get; set; }
    [Parameter] public string? Class { get; set; }
    [Parameter] public EventCallback<string> ValueChanged { get; set; }
    [Parameter] public EventCallback<MouseEventArgs> OnEndIconClick { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? ExtraAttrs { get; set; }

    private async Task HandleInput(ChangeEventArgs e)
    {
        Value = e.Value?.ToString() ?? "";
        if (ValueChanged.HasDelegate) await ValueChanged.InvokeAsync(Value);
    }
}
