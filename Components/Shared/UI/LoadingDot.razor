@* Three pulsing dots — used inside buttons and inline loaders. *@

<span class="inline-flex items-center gap-1" aria-label="Loading">
    <span class="w-1 h-1 rounded-full bg-current animate-pulse-dot"></span>
    <span class="w-1 h-1 rounded-full bg-current animate-pulse-dot" style="animation-delay: 0.15s"></span>
    <span class="w-1 h-1 rounded-full bg-current animate-pulse-dot" style="animation-delay: 0.3s"></span>
</span>
