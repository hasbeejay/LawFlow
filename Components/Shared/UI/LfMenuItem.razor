@if (!string.IsNullOrEmpty(Href))
{
    <a href="@Href" class="flex items-center gap-2.5 px-3 py-2 rounded-xs text-sm text-ink hover:bg-ink/5 transition-colors cursor-pointer">
        @if (!string.IsNullOrEmpty(Icon)) { <LfIcon Name="@Icon" Size="15" Class="text-muted" /> }
        <span class="flex-1">@ChildContent</span>
    </a>
}
else
{
    <button type="button" @onclick="OnClick"
            class="w-full flex items-center gap-2.5 px-3 py-2 rounded-xs text-sm text-ink hover:bg-ink/5 transition-colors text-left">
        @if (!string.IsNullOrEmpty(Icon)) { <LfIcon Name="@Icon" Size="15" Class="text-muted" /> }
        <span class="flex-1">@ChildContent</span>
    </button>
}

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string? Icon { get; set; }
    [Parameter] public string? Href { get; set; }
    [Parameter] public EventCallback<MouseEventArgs> OnClick { get; set; }
}
