@* Inline SVG icon set (Lucide-derived, hand-curated for this app). Stroke-based, currentColor. *@

@{
    var s = (int)Size;
    var clsAll = string.IsNullOrWhiteSpace(Class) ? "" : $" {Class}";
}

<svg xmlns="http://www.w3.org/2000/svg" width="@s" height="@s" viewBox="0 0 24 24"
     fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"
     class="inline-block shrink-0@(clsAll)" aria-hidden="true">
    @switch (Name?.ToLowerInvariant())
    {
        case "gavel":
            <path d="m14 13-7.5 7.5c-.83.83-2.17.83-3 0s-.83-2.17 0-3L11 10" />
            <path d="m16 16 6-6" />
            <path d="m8 8 6-6" />
            <path d="m9 7 8 8" />
            <path d="m21 11-8-8" />
            break;
        case "menu":
            <line x1="4" x2="20" y1="6" y2="6" /><line x1="4" x2="20" y1="12" y2="12" /><line x1="4" x2="20" y1="18" y2="18" />
            break;
        case "x":
            <path d="M18 6 6 18" /><path d="m6 6 12 12" />
            break;
        case "bell":
            <path d="M10.268 21a2 2 0 0 0 3.464 0" /><path d="M3.262 15.326A1 1 0 0 0 4 17h16a1 1 0 0 0 .74-1.673C19.41 13.956 18 12.499 18 8A6 6 0 0 0 6 8c0 4.499-1.411 5.956-2.738 7.326" />
            break;
        case "sun":
            <circle cx="12" cy="12" r="4" />
            <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" />
            break;
        case "moon":
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
            break;
        case "user":
            <circle cx="12" cy="7" r="4" />
            <path d="M5.5 21a6.5 6.5 0 0 1 13 0" />
            break;
        case "log-out":
            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
            <polyline points="16 17 21 12 16 7" />
            <line x1="21" x2="9" y1="12" y2="12" />
            break;
        case "layout-dashboard":
            <rect width="7" height="9" x="3" y="3" rx="1.5" />
            <rect width="7" height="5" x="14" y="3" rx="1.5" />
            <rect width="7" height="9" x="14" y="12" rx="1.5" />
            <rect width="7" height="5" x="3" y="16" rx="1.5" />
            break;
        case "folder-open":
            <path d="m6 14 1.45-2.9A2 2 0 0 1 9.24 10H20a2 2 0 0 1 1.94 2.5l-1.55 6a2 2 0 0 1-1.94 1.5H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h3.93a2 2 0 0 1 1.66.9l.82 1.2a2 2 0 0 0 1.66.9H18a2 2 0 0 1 2 2v2" />
            break;
        case "scale":
            <path d="m16 16 3-8 3 8c-.87.65-1.92 1-3 1s-2.13-.35-3-1Z" />
            <path d="m2 16 3-8 3 8c-.87.65-1.92 1-3 1s-2.13-.35-3-1Z" />
            <path d="M7 21h10" /><path d="M12 3v18" /><path d="M3 7h2c2 0 5-1 7-2 2 1 5 2 7 2h2" />
            break;
        case "briefcase":
            <rect width="20" height="14" x="2" y="7" rx="2" />
            <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16" />
            break;
        case "file-plus":
            <path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z" />
            <polyline points="14 2 14 8 20 8" />
            <line x1="12" x2="12" y1="18" y2="12" /><line x1="9" x2="15" y1="15" y2="15" />
            break;
        case "shield":
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
            break;
        case "calendar":
            <path d="M8 2v4M16 2v4" />
            <rect width="18" height="18" x="3" y="4" rx="2" />
            <path d="M3 10h18" />
            break;
        case "file-text":
            <path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z" />
            <polyline points="14 2 14 8 20 8" />
            <line x1="16" x2="8" y1="13" y2="13" /><line x1="16" x2="8" y1="17" y2="17" />
            break;
        case "users":
            <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" />
            <circle cx="9" cy="7" r="4" />
            <path d="M22 21v-2a4 4 0 0 0-3-3.87" />
            <path d="M16 3.13a4 4 0 0 1 0 7.75" />
            break;
        case "history":
            <path d="M3 12a9 9 0 1 0 3-6.74L3 8" /><path d="M3 3v5h5" />
            <path d="M12 7v5l4 2" />
            break;
        case "eye":
            <path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z" />
            <circle cx="12" cy="12" r="3" />
            break;
        case "eye-off":
            <path d="M9.88 9.88a3 3 0 1 0 4.24 4.24" />
            <path d="M10.73 5.08A10.43 10.43 0 0 1 12 5c7 0 10 7 10 7a13.16 13.16 0 0 1-1.67 2.68" />
            <path d="M6.61 6.61A13.526 13.526 0 0 0 2 12s3 7 10 7a9.74 9.74 0 0 0 5.39-1.61" />
            <line x1="2" x2="22" y1="2" y2="22" />
            break;
        case "arrow-right":
            <path d="M5 12h14" /><path d="m12 5 7 7-7 7" />
            break;
        case "arrow-up-right":
            <path d="M7 7h10v10" /><path d="M7 17 17 7" />
            break;
        case "search":
            <circle cx="11" cy="11" r="7" /><path d="m21 21-4.3-4.3" />
            break;
        case "plus":
            <path d="M5 12h14" /><path d="M12 5v14" />
            break;
        case "check":
            <path d="M20 6 9 17l-5-5" />
            break;
        case "check-circle":
            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" /><polyline points="22 4 12 14.01 9 11.01" />
            break;
        case "alert-circle":
            <circle cx="12" cy="12" r="10" /><line x1="12" x2="12" y1="8" y2="12" /><line x1="12" x2="12.01" y1="16" y2="16" />
            break;
        case "alert-triangle":
            <path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z" />
            <line x1="12" x2="12" y1="9" y2="13" /><line x1="12" x2="12.01" y1="17" y2="17" />
            break;
        case "info":
            <circle cx="12" cy="12" r="10" /><line x1="12" x2="12" y1="16" y2="12" /><line x1="12" x2="12.01" y1="8" y2="8" />
            break;
        case "more-horizontal":
            <circle cx="12" cy="12" r="1" /><circle cx="19" cy="12" r="1" /><circle cx="5" cy="12" r="1" />
            break;
        case "chevron-down":
            <path d="m6 9 6 6 6-6" />
            break;
        case "chevron-right":
            <path d="m9 18 6-6-6-6" />
            break;
        case "chevron-left":
            <path d="m15 18-6-6 6-6" />
            break;
        case "bolt":
        case "zap":
            <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2" />
            break;
        case "command":
            <path d="M18 3a3 3 0 0 0-3 3v12a3 3 0 0 0 3 3 3 3 0 0 0 3-3 3 3 0 0 0-3-3H6a3 3 0 0 0-3 3 3 3 0 0 0 3 3 3 3 0 0 0 3-3V6a3 3 0 0 0-3-3 3 3 0 0 0-3 3 3 3 0 0 0 3 3h12a3 3 0 0 0 3-3 3 3 0 0 0-3-3z" />
            break;
        case "circle-dot":
            <circle cx="12" cy="12" r="10" /><circle cx="12" cy="12" r="2.5" fill="currentColor" />
            break;
        case "filter":
            <polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3" />
            break;
        case "trending-up":
            <polyline points="22 7 13.5 15.5 8.5 10.5 2 17" /><polyline points="16 7 22 7 22 13" />
            break;
        default:
            <circle cx="12" cy="12" r="9" />
            break;
    }
</svg>

@code {
    [Parameter, EditorRequired] public string Name { get; set; } = "circle-dot";
    [Parameter] public int Size { get; set; } = 18;
    [Parameter] public string? Class { get; set; }
}
